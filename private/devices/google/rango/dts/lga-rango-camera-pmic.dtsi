/*
 * camera PMIC device tree for rango
 *
 * Copyright 2024 Google LLC.
 *
 */

/ {
	fragment@camera_supply {
		target-path = "/";
		__overlay__ {
			cam_pp1050: cam_supply@0 {
				compatible = "regulator-fixed";
				status = "okay";
				regulator-name = "PP1050_CAM";
				regulator-min-microvolt = <1050000>;
				regulator-max-microvolt = <1050000>;
				/* 2ms */
				regulator-enable-ramp-delay = <2000>;
				enable-active-high;
				/* PMICM2RCAM_VDIG_EN */
				gpio = <PMICM2RCAM_VDIG_EN(GPIO_ACTIVE_HIGH)>;
			};
		};
	};
};

&lsioe_cli7_i2c {
	slg51002: slg51002@75 {
		compatible = "dlg,slg51002";
		reg = <0x75>;
		status = "ok";
		dlg,cs-gpios = <PMICS2CAM_PMIC_EN(GPIO_ACTIVE_HIGH)>;
		dlg,reg-init-cells = <2>;
		dlg,reg-init = <0x111A 0x45>, <0x111B 0x53>, <0x111C 0x54>,
						<0x111D 0x4D>, <0x3164 0x81>,
						<0x3264 0x81>, <0x1119 0x00>,
						<0x3163 0x03>, <0x3263 0x03>;

		regulators {
			slg51002_ldo1: ldo1 {
				regulator-name = "ldo1";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3750000>;
				vin1_2-supply = <&cam_pp3200_bb>;
			};

			slg51002_ldo2: ldo2 {
				regulator-name = "ldo2";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3750000>;
				vin1_2-supply = <&cam_pp3200_bb>;
			};

			slg51002_ldo3: ldo3 {
				regulator-name = "ldo3";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3750000>;
				vin3-supply = <&cam_pp3200_bb>;
			};

			slg51002_ldo4: ldo4 {
				regulator-name = "ldo4";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3750000>;
				vin4-supply = <&cam_pp3200_bb>;
			};

			slg51002_ldo5: ldo5 {
				regulator-name = "ldo5";
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3750000>;
				vin5-supply = <&cam_pp3200_bb>;
			};

			slg51002_ldo6: ldo6 {
				regulator-name = "ldo6";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
				vin6-supply = <&cam_pp1050>;
			};

			slg51002_ldo7: ldo7 {
				regulator-name = "ldo7";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
				vin7-supply = <&cam_pp1050>;
			};

			slg51002_ldo8: ldo8 {
				regulator-name = "ldo8";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
				vin8-supply = <&cam_pp1050>;
			};

			slg51002_gpio1: gpio1 {
				regulator-name = "gpio1";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
			};

			slg51002_gpio2: gpio2 {
				regulator-name = "gpio2";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
			};

			slg51002_gpio3: gpio3 {
				regulator-name = "gpio3";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
			};

			slg51002_gpio4: gpio4 {
				regulator-name = "gpio4";
				regulator-min-microvolt = <400000>;
				regulator-max-microvolt = <1675000>;
			};
		};

		slg51002_gpio: slg51002_gpio {
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <8>;
			gpio-ranges = <&slg51002_pinctrl 0 0 8>;
		};

		slg51002_pinctrl: slg51002_pinctrl {
		};
	};

	/* RT6160 */
	cam_pp3200_bb: cam_supply@77 {
		compatible = "richtek,rt6160";
		reg = <0x77>;
		/* CAM_BB_EN */
		enable-gpios = <PMICS2CAM_BB_EN(GPIO_ACTIVE_HIGH)>;
		status = "ok";
		regulator-name = "PP3200_CAM_BB";
		regulator-min-microvolt = <3200000>;
		regulator-max-microvolt = <3200000>;
		/* 2ms */
		regulator-enable-ramp-delay = <2000>;
	};
};
