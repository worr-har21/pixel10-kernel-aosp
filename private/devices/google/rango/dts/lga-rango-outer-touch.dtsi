&outer_touch {
	status = "ok";

	compatible = "synaptics,tcm-spi";
	reg = <0>;
	spi-max-frequency = <20000000>;
	rx-sample-delay-ns = <25>;

	synaptics,avdd-name = "avdd";
	synaptics,vdd-name = "vdd";
	synaptics,power-delay-ms = <200>;
	synaptics,irq-gpio = <TS0_2_AOC_INT_L_1V2(GPIO_ACTIVE_LOW)>;
	synaptics,irq-flags = <0x2008>; /* IRQF_ONESHOT | IRQF_TRIGGER_LOW */
	synaptics,irq-on-state = <0>;
	synaptics,reset-gpio = <PMICS2TS0_RESET_L_1V2(GPIO_ACTIVE_LOW)>;
	synaptics,reset-on-state = <0>;
	synaptics,reset-active-ms = <20>;
	synaptics,reset-delay-ms = <200>;
	synaptics,spi-mode = <0>;
	synaptics,spi-byte-delay-us = <0>;
	synaptics,spi-block-delay-us = <0>;
	synaptics,pixels-per-mm = <20>;
	synaptics,compression-threshold = <0>;

	synaptics,panel_map = <&google_gs_rgeb 0>;
	synaptics,firmware_names = "synaptics.img";

	goog,panel_map = <&google_gs_rgeb 0>;
	goog,firmware_names = "synaptics.img";

	goog,dev-id = <1>;
	goog,offload-device-name = "outer";
	goog,touch_offload_id = /bits/ 8 <'r''g''5''1'>; /* outer: 1; inner 0 */
	goog,display-resolution = /bits/ 16 <1280 2364>;
	goog,channel-num = /bits/ 16 <17 37>;
	goog,offload-caps-data-types = /bits/ 16 <0x1F>;
	goog,offload-caps-scan-types = /bits/ 16 <0xC0>;
	goog,offload-caps-context-channel-types = /bits/ 16 <0x0100>;
	goog,offload-caps-coord-filter;
	goog,v4l2-enabled;
	goog,offload-enabled;

	goog,late-sense-on-enabled;
	goog,init-mf-mode = <4>;
	goog,manual-heatmap-from-irq;
	goog,reset-after-selftest;
	goog,coord-filter-enabled;
	goog,timestamp-correction-enabled;
	goog,tbn-enabled;
	goog,tbn-protection-enabled;

