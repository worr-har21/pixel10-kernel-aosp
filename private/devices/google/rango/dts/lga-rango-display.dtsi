#include <dt-bindings/gpio/gpio.h>

&lsios_cli4_i2c {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	clock-frequency = <400000>;
	s2dos07x02: s2dos07x02@60 {
		compatible = "samsung,s2dos07x02";
		reg = <0x60>;
		status = "okay";
		regulator-name = "s2dos07x02-pmic";
		regulator-max-microvolt = <2100000>;
		regulator-min-microvolt = <850000>;
	};
};

&lsioe_cli14_i2c {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	clock-frequency = <400000>;
	s2dos07x02_cli14: s2dos07x02@60 {
		compatible = "samsung,s2dos07x02";
		reg = <0x60>;
		status = "okay";
		regulator-name = "s2dos07x02-pmic";
		regulator-max-microvolt = <2100000>;
		regulator-min-microvolt = <850000>;
	};
};

&gs_dsi0_connector {
	google,preferred-panel = <&google_gs_rgeb>;
	/* 0: primary, 1: secondary */
	google,device-index = <1>;

	google_gs_rgeb: panel-gs-rgeb {
		compatible = "google,gs-rgeb";
		label = "google-rgeb";
		channel = <0>;
		allowed-hs-clks = <865 756>;

		/* reset, power */
		reset-gpios = <PMICS2DISP0_RESET_L(GPIO_ACTIVE_HIGH)>;
		vci-supply = <&ldo_18s_reg>;
		vddi-supply = <&buck_12s_reg>;
		vddd-supply = <&s2dos07x02_cli14>;
		vddd-normal-microvolt = <1000000>;
		vddd-lp-microvolt    = <962500>;
    };
};

&gs_dsi1_connector {
	google,preferred-panel = <&google_gs_rgea>;
	/* 0: primary, 1: secondary */
	google,device-index = <0>;

	google_gs_rgea: panel-gs-rgea {
		compatible = "google,gs-rgea";
		label = "google-rgea";
		channel = <0>;
		/* 0: normal, 1: bottom up, 2: left up, 3: right up */
		orientation = <2>;
		allowed-hs-clks = <1388 1468>;

		/* reset, power */
		reset-gpios = <PMICS2DISP1_RESET_L(GPIO_ACTIVE_HIGH)>;
		vci-supply = <&ldo_14m_reg>;
		vddi-supply = <&buck_12s_reg>;
		vddd-supply = <&s2dos07x02>;
		vddd-normal-microvolt = <850000>;
	};
};

&dsi2h0 {
	status = "ok";
	datarate = <865>;
};

&dsi2h1 {
	status = "ok";
	datarate = <1468>;
};

