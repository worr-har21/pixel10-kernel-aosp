			/* EEPROM for INNER FRONT CAMERA */
			eeprom1: eeprom@1 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-svarog";

				/* I2C */
				i2c-bus = <&lsioe_cli8_i2c>;
