# Please put soc configs to private/devices/google/lga/device.bazelrc, which is used by lga_base here.
build:muzel --config=lga_base
build:muzel --//private/devices/google/common:kernel=//private/devices/google/muzel:kernel
build:muzel --//private/google-modules/touch/common:touch_udfps_notification=enabled
