/dts-v1/;
/plugin/;

#define BATTERY_EEPROM_1K

#include "lga-deepspace-pinctrl.dtsi"
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include "lga-deepspace-coresight-disabled.dtsi"

/ {
	board_id = <0x78000>;
	board_rev = <0x00010004>;
	fragment@boardbase {
		target-path = "/";
		__overlay__ {
			model = "SoC Hybrid emulator board based on LGA";
			compatible = "google,lga-soc-hybrid", "google,lga-soc-hybrid-emulator";
		};
	};
};

/ {
	fragment@virt_dp {
		target-path = "/";
		__overlay__ {
			v9p1: virtio_block@4010000 {
				compatible = "virtio,mmio";
				reg = <0x0 0x4010000 0 0x10000>;
				interrupts = <GIC_SPI 958 IRQ_TYPE_LEVEL_HIGH 0>;
			};

			// Virtio block for loading images
			virtio0: virtio_block@4020000 {
				compatible = "virtio,mmio";
				reg = <0x0 0x4020000 0 0x10000>;
				interrupts = <GIC_SPI 959 IRQ_TYPE_LEVEL_HIGH 0>;
			};
		};
	};

	fragment@virt_uart {
		target-path = "/";
		// Virtualized uart
		__overlay__ {
			sysclk: clk100000000 {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <100000000>;
				clock-output-names = "sysclk";
			};
			// soc-hybrid platform uses arm pl011 uart
			uart@40000000 {
				compatible = "arm,pl011", "arm,primecell";
				reg = <0x0 0x4000000 0x0 0x1000>;
				interrupts = <GIC_SPI 957 IRQ_TYPE_LEVEL_HIGH 0>;
				clock-names = "uartclk", "apb_pclk";
				clocks = <&sysclk>, <&sysclk>;
			};
		};
	};
};

// Disable UFS nodes, we don't support UFS on soc-hybrid platform
&ufs {
	status = "disabled";
};

&inf_smmu {
	status = "disabled";
};

&inftcu_pulse_aggr_0_intr {
	status = "disabled";
};

&inftcu_multicast_aggr_3_intr {
	status = "disabled";
};

// Disable eh nodes for soc-hybrid platform
