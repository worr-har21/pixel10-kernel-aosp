/* Disable unsupported sswrp on default soc-hybrid build */
&sswrp_gsw {
	status = "disabled";
};

&gsw_level_aggr_01_intr {
	status = "disabled";
};

&chosen {
	bootargs = "earlycon=pl011,0x4000000 console=ttyAMA0,115200n8 norandmaps ro androidboot.force_normal_boot=1 androidboot.hardware.platform=gem5 loglevel=8 init=/init maxcpus=1 androidboot.boot_devices=4020000.virtio_block enforcing=0 pvrsrvkm.FabricCoherencyOverride=0 printk.devkmsg=on firmware_class.path=/vendor/firmware fw_devlink=rpm androidboot.selinux=permissive deferred_probe_timeout=50";
	/* hardcode rng seed for gem5 */
	rng-seed = "deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef /
		    deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef /
		    deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef";
};

&gpu {
	pre-silicon;
	emulator;
};

&cpm_ap_ns_req_mba_client_0 {
	status = "okay";
};

&cpm_ap_ns_resp_mba_client_1 {
	status = "okay";
};

&goog_mba_cpm_iface {
	status = "okay";
};

/* Zebu have no working PMIC RTL, disable all PMIC drivers. */
&da9188mfd {
	status = "disabled";
};

/* Config setting for power-controller on emu platform. */
&power_controller {
	in_emulation;
};

/* Config setting for cpm_clk on emu platform. */
&cpm_clk {
	in_emulation;
};

/* Disable cpufreq because it generates KP on SoC Hybrid. */
&cpufreq {
	status = "disabled";
};


/* No plan to enable deeper CPU low power modes on LGA pre-silicon. */
&sst {
	status = "disabled";
};
