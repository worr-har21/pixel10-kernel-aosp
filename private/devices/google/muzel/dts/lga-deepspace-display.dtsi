#include <dt-bindings/gpio/gpio.h>

&disp_vddd {
	status = "okay";
	gpio = <PMICS2DISP0_BUCK_EN(GPIO_ACTIVE_HIGH)>;
};

&lsioe_cli14_i2c {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	clock-frequency = <400000>;
	s2dos07x02: s2dos07x02@60 {
		compatible = "samsung,s2dos07x02";
		reg = <0x60>;
		status = "okay";
		regulator-name = "s2dos07x02-pmic";
	};
	tps628600: tps628600@40 {
		compatible = "ti,tps628600";
		reg = <0x40>;
		status = "okay";
		regulator-name = "tps628600-reg";
		enable-gpios = <PMICS2DISP0_BUCK_EN(GPIO_ACTIVE_HIGH)>;
	};
};

&gs_dsi0_connector {
	google,preferred-panel = <&google_gs_km4>;

	google_gs_flea: panel-gs-flea {
		compatible = "google,gs-flea";
		label = "google-flea";
		channel = <0>;

		/* reset, power */
		reset-gpios = <PMICS2DISP0_RESET_L(GPIO_ACTIVE_HIGH)>;
		vci-supply = <&ldo_14m_reg>;
		vddi-supply = <&buck_12s_reg>;
		vddd-supply = <&tps628600>;
		vddd-normal-microvolt = <1062500>;
		vddd-lp-microvolt     = <1000000>;

		/* touch */
		touch = <&spitouch>;
	};

	google_gs_fleb: panel-gs-fleb {
		compatible = "google,gs-fleb";
		label = "google-fleb";
		channel = <0>;

		/* reset, power */
		reset-gpios = <PMICS2DISP0_RESET_L(GPIO_ACTIVE_HIGH)>;
		vci-supply = <&ldo_14m_reg>;
		vddi-supply = <&buck_12s_reg>;
		vddd-supply = <&tps628600>;
		vddd-normal-microvolt = <1112500>;
		vddd-lp-microvolt     = <1062500>;

		/* touch */
		touch = <&spitouch>;
	};

	google_gs_bzea: panel-gs-bzea {
		compatible = "google,gs-bzea";
		label = "google-bzea";
		channel = <0>;

		/* reset, power */
