		/* reset, power */
		reset-gpios = <PMICS2DISP0_RESET_L(GPIO_ACTIVE_HIGH)>;
		vci-supply = <&ldo_14m_reg>;
		vddi-supply = <&buck_12s_reg>;
		vddd-supply = <&disp_vddd>;

		/* touch */
		touch = <&spitouch>;
	};
	google_gs_tk4c: panel-gs-tk4c {

		compatible = "google,gs-tk4c";
