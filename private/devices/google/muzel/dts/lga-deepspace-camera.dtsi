			/* EEPROM SMAUG for DOKKAEBI */
			eeprom1: eeprom@1 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-dokkaebi";

				/* I2C */
				i2c-bus = <&lsioe_cli8_i2c>;
				i2c-addr = <0x51>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* Power supplies */
				vio-supply = <&ldo_22s_reg>;

				/* Power up sequence */
				power-up-seqs =
					"vio";
				power-up-seq-types =
					"regulator";
				power-up-seq-delays-us =
					<0>;
				/* Power down sequence */
				power-down-seqs =
					"vio";
				power-down-seq-types =
					"regulator";
				power-down-seq-delays-us =
					<0>;
			};

			/* EEPROM SMAUG for UW */
			eeprom2: eeprom@2 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-taotie-uw";
				/* I2C */
				i2c-bus = <&lsioe_cli13_i2c>;
				i2c-addr = <0x50>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* Power up sequence */
				power-up-seqs =
					"vio";
				power-up-seq-types =
					"regulator";
				power-up-seq-delays-us =
					<0>;
				/* Power down sequence */
				power-down-seqs =
					"vio";
				power-down-seq-types =
					"regulator";
				power-down-seq-delays-us =
					<0>;

				i2c-lock-group-id = <2>;
			};

			/* EEPROM HUMBABA for Tele */
			eeprom3: eeprom@3 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-humbaba";

				/* I2C */
				i2c-bus = <&lsios_cli0_i2c>;
				i2c-addr = <0x61>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* GPIOs */
				shared-reset-gpios = <AP2RTCAM_AF_OIS_RST(GPIO_ACTIVE_HIGH)>;

				/* Power supplies */
				ldo5-supply = <&slg51002_ldo5>;
				gpio3-supply = <&slg51002_gpio3>;
				vio-supply = <&ldo_22s_reg>;

				/* Power up sequence */
				power-up-seqs =
					"vio",
					"ldo5",
					"gpio3",
					"shared-reset";
				power-up-seq-types =
					"regulator",
					"regulator",
					"regulator",
					"gpio";
				power-up-seq-delays-us =
					<0
					 1000
					 1000
					 0>;

				/* Power down sequence */
				power-down-seqs =
					"shared-reset",
					"gpio3",
					"ldo5",
					"vio";
				power-down-seq-types =
					"gpio",
					"regulator",
					"regulator",
					"regulator";
				power-down-seq-delays-us =
					<1000
					 1000
					 0
					 0>;
			};

			/* EEPROM SMAUG for TAOTIE Front */
			eeprom4: eeprom@4 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-taotie-front";
				/* I2C */
				i2c-bus = <&lsios_cli3_i2c>;
				i2c-addr = <0x50>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* Power up sequence */
				power-up-seqs =
					"vio";
				power-up-seq-types =
					"regulator";
				power-up-seq-delays-us =
					<0>;
				/* Power down sequence */
				power-down-seqs =
					"vio";
				power-down-seq-types =
					"regulator";
				power-down-seq-delays-us =
					<0>;

				i2c-lock-group-id = <1>;
			};

			/* EEPROM SMAUG for SVAROG OUTER */
			eeprom6: eeprom@6 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-svarog-outer";

				/* I2C */
				i2c-bus = <&lsioe_cli8_i2c>;
				i2c-addr = <0x50>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* Power supplies */
				vio-supply = <&ldo_22s_reg>;

				/* Power up sequence */
				power-up-seqs =
					"vio";
				power-up-seq-types =
					"regulator";
				power-up-seq-delays-us =
					<1000>;
				/* Power down sequence */
				power-down-seqs =
					"vio";
				power-down-seq-types =
					"regulator";
				power-down-seq-delays-us =
					<0>;
			};

			/* ============== END OF EEPROM CONFIG 1 ============== */

			/* ============== START OF EEPROM CONFIG 2 ============== */

			/* EEPROM NESSIE for BARGHEST */
			eeprom7: eeprom@7 {
				compatible = "google,lwis-i2c-device";
				/* Device node name */
				node-name = "eeprom-nessie";
				/* I2C */
				i2c-bus = <&lsios_cli1_i2c &lsios_cli1_i3c>;
				i2c-addr = <0x24>;
				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <32>;
				/* Power supplies */
				vio-supply = <&ldo_22s_reg>; /* VIO */
				ldo5-supply = <&slg51002_ldo5>; /* Actuator OIS Drive IC */
				ldo4-supply = <&slg51002_ldo4>;  /* Actuator VM */

				/* Power up sequence */
				power-up-seqs =
					"vio",
					"ldo5",
					"ldo4";
				power-up-seq-types =
					"regulator",
					"regulator",
					"regulator";
				power-up-seq-delays-us =
					<0
					 0
					 0>;
				/* Power down sequence */
				power-down-seqs =
					"ldo4",
					"ldo5",
					"vio";
				power-down-seq-types =
					"regulator",
					"regulator",
					"regulator";
				power-down-seq-delays-us =
					<0
					 0
					 0>;

				i2c-lock-group-id = <0>;
			};

			/* EEPROM SMAUG for LESHEN-UW */
			eeprom5: eeprom@5 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "eeprom-smaug-leshen-uw";

				/* I2C */
				i2c-bus = <&lsioe_cli8_i2c>;
				i2c-addr = <0x50>;

				/* Registers */
				reg-addr-bitwidth = <16>;
				reg-value-bitwidth = <8>;

				/* Power supplies */
				vio-supply = <&ldo_22s_reg>;

				/* Power up sequence */
				power-up-seqs =
					"vio";
				power-up-seq-types =
					"regulator";
				power-up-seq-delays-us =
					<0>;
				/* Power down sequence */
				power-down-seqs =
					"vio";
				power-down-seq-types =
					"regulator";
				power-down-seq-delays-us =
					<0>;
			};

			/* ============== END OF EEPROM CONFIG 2 ============== */

			flash0: flash@0 {
				compatible = "google,lwis-i2c-device";

				/* Device node name */
				node-name = "flash-lm3644";

				/* I2C */
				i2c-bus = <&lsioe_cli7_i2c>;
				i2c-addr = <0x63>;

				/* Registers */
				reg-addr-bitwidth = <8>;
				reg-value-bitwidth = <8>;

				/* GPIOs */
				/* AP2FLASH_EN */
				enable-gpios = <AP2FLASH_EN(GPIO_ACTIVE_HIGH)>;

				power-up-seqs = "enable";
				power-up-seq-types = "gpio";
				power-up-seq-delays-us = <0>;

				power-down-seqs = "enable";
				power-down-seq-types = "gpio";
				power-down-seq-delays-us = <0>;
			};
		};
	};
};
