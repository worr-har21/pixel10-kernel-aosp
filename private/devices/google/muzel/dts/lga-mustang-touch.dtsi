	goog,coord-filter-enabled;
	goog,reset-after-selftest;
	goog,init-mf-mode = <4>;
	goog,late-sense-on-enabled;
	goog,timestamp-correction-enabled;

	synaptics,metadata-enabled;
	synaptics,pixels-per-mm = <19>;

