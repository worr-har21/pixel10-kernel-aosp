		function = "hsios_stby_ufs";
	};

	ap_far_clk_76p8mhz_r: ap_far_clk_76p8mhz_r {
		/* System - Clock */
		pins = "XHSIOS_CLKBUF_1";
		input-enable;
		output-disable;
		function = "hsios_stby_clkbuf";
	};
};

