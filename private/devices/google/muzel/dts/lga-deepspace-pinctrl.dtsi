		"CP2AP_PCIE_CLKREQ0_L_1V2",
		"AP2NFC_CHIP_EN_1V2",
		"AP2CP_PCIE_PERST0_L_1V2",
		"NFC2AP_PWR_STATE_1V2",
		"XHSION_GPIO0_1V2",
		"AP2ESE_SPI_RESET_L_1V2",
		"AP2ESE_CHIP_EN_1V2",
		"NFC2AP_COEX_1V2",
		"AP2NFC_COEX_1V2",
		"ESE2AP_PWR_STATE_1V2",
		"AP2NFC_WAKEUP_REQ_1V2",
		"HSION_ATB0";

	ap2cp_pcie_perst0_l_1v2: ap2cp_pcie_perst0_l_1v2 {
		/* Connectivity - Modem */
		pins = "XHSION_PCIE0_PERSTN0";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2cp_pcie_perst0_l_1v2_sleep: ap2cp_pcie_perst0_l_1v2_sleep {
		/* Connectivity - Modem - Sleep */
		pins = "XHSION_PCIE0_PERSTN0";
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2ese_chip_en_1v2: ap2ese_chip_en_1v2 {
		/* Security - ESE */
		pins = "XHSION_GPIO2";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2ese_chip_en_1v2_sleep: ap2ese_chip_en_1v2_sleep {
		/* Security - ESE - Sleep */
		pins = "XHSION_GPIO2";
		input-enable;
		output-high;
		function = "hsion_gpio";
	};

	ap2ese_spi_reset_l_1v2: ap2ese_spi_reset_l_1v2 {
		/* Security - ESE */
		pins = "XHSION_GPIO1";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2ese_spi_reset_l_1v2_sleep: ap2ese_spi_reset_l_1v2_sleep {
		/* Security - ESE - Sleep */
		pins = "XHSION_GPIO1";
		input-enable;
		output-high;
		function = "hsion_gpio";
	};

	ap2nfc_chip_en_1v2: ap2nfc_chip_en_1v2 {
		/* Connectivity - NFC */
		pins = "XHSION_GPIO7";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2nfc_chip_en_1v2_sleep: ap2nfc_chip_en_1v2_sleep {
		/* Connectivity - NFC - Sleep */
		pins = "XHSION_GPIO7";
		input-enable;
		output-high;
		function = "hsion_gpio";
	};

	ap2nfc_coex_1v2: ap2nfc_coex_1v2 {
		/* Connectivity - NFC */
		pins = "XHSION_GPIO4";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2nfc_coex_1v2_sleep: ap2nfc_coex_1v2_sleep {
		/* Connectivity - NFC - Sleep */
		pins = "XHSION_GPIO4";
		input-enable;
		output-low;
		function = "hsion_gpio";
	};

	ap2nfc_wakeup_req_1v2: ap2nfc_wakeup_req_1v2 {
		/* Connectivity - NFC */
		pins = "XHSION_GPIO6";
		bias-disable;
		drive-strength = <0>;
		input-enable;
		output-enable;
		function = "hsion_gpio";
	};

	ap2nfc_wakeup_req_1v2_sleep: ap2nfc_wakeup_req_1v2_sleep {
		/* Connectivity - NFC - Sleep */
		pins = "XHSION_GPIO6";
		input-enable;
		output-low;
		function = "hsion_gpio";
	};

	cp2ap_pcie_clkreq0_l_1v2: cp2ap_pcie_clkreq0_l_1v2 {
		/* Connectivity - Modem */
		pins = "XHSION_PCIE0_CLKREQN0";
		bias-disable;
		input-enable;
		output-disable;
		function = "hsion_pcie0";
	};

	ese2ap_pwr_state_1v2: ese2ap_pwr_state_1v2 {
		/* Security - ESE */
		pins = "XHSION_GPIO5";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	ese2ap_pwr_state_1v2_sleep: ese2ap_pwr_state_1v2_sleep {
		/* Security - ESE - Sleep */
		pins = "XHSION_GPIO5";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	hsion_atb0: hsion_atb0 {
		/* System - gChips */
		pins = "XHSION_ATB0";
		input-enable;
		output-disable;
		function = "None";
	};

	nfc2ap_coex_1v2: nfc2ap_coex_1v2 {
		/* Connectivity - NFC */
		pins = "XHSION_GPIO3";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	nfc2ap_coex_1v2_sleep: nfc2ap_coex_1v2_sleep {
		/* Connectivity - NFC - Sleep */
		pins = "XHSION_GPIO3";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	nfc2ap_pwr_state_1v2: nfc2ap_pwr_state_1v2 {
		/* Connectivity - NFC */
		pins = "XHSION_GPIO8";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	nfc2ap_pwr_state_1v2_sleep: nfc2ap_pwr_state_1v2_sleep {
		/* Connectivity - NFC - Sleep */
		pins = "XHSION_GPIO8";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	xhsion_gpio0_1v2: xhsion_gpio0_1v2 {
		/* Dev - Spare */
		pins = "XHSION_GPIO0";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};

	xhsion_gpio0_1v2_sleep: xhsion_gpio0_1v2_sleep {
		/* Dev - Spare - Sleep */
		pins = "XHSION_GPIO0";
		bias-pull-down;
		input-enable;
		output-disable;
		function = "hsion_gpio";
	};
};

