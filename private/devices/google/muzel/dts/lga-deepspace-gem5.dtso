	status = "okay";
};

&goog_mba_aggr_gdmc_crit {
	status = "okay";
};

&goog_mba_gdmc_iface {
	status = "okay";
};

/ {
	fragment@fixed-clock {
		target-path = "/";
		__overlay__ {
			clk_200mhz: clk_200mhz {
				compatible = "fixed-clock";
				#clock-cells = <0>;
				clock-frequency = <200000000>;
			};
		};
	};
};

&lsion_cli16_uart {
	clocks = <&clk_200mhz>;
	clock-names = "baudclk";
	pinctrl-0 = <&cli16_uart_conf>;
	pinctrl-1 = <&cli16_uart_conf>;
};

&ufs {
	google,skip-ufs-phy-init;
};

&cpm_ap_ns_req_mba_client_0 {
	status = "okay";
};

&cpm_ap_ns_resp_mba_client_1 {
	status = "okay";
};

&goog_mba_cpm_iface {
	status = "okay";
};

&amb_smmu {
	status = "disabled";
};

&gdmc_pulse_aggr_dhub_irq {
	status = "disabled";
};

&gdmc_level_aggr_0_intr {
	status = "disabled";
};
