/dts-v1/;
/plugin/;

#define BATTERY_EEPROM_1K

/* Use deepspace GPIO configs. */
#include "lga-deepspace-pinctrl.dtsi"
#include "lga-deepspace-coresight-disabled.dtsi"
/ {
	board_id = <0x78000>;
	board_rev = <0x00010001>;
	fragment@boardbase {
		target-path = "/";
		__overlay__ {
			model = "EMULATOR board based on LGA";
			compatible = "google,lga", "google,lga-emulator";
		};
	};
};

&memss_level_aggr_fmc_irq_h1_0 {
	status = "disabled";
};

&memss_level_aggr_fmc_irq_h1_1 {
	status = "disabled";
};

&memss_level_aggr_fmc_irq_h1_2 {
	status = "disabled";
};

&memss_level_aggr_fmc_irq_h1_3 {
	status = "disabled";
};

