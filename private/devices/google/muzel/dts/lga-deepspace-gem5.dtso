&chosen {
	bootargs = "earlycon=uart8250,mmio32,0xdb62000 norandmaps ro androidboot.force_normal_boot=1 loglevel=8 init=/init console=ttyS0,12500000n8 8250.nr_uarts=4 androidboot.boot_devices=3c400000.ufs printk.devkmsg=on firmware_class.path=/vendor/firmware fw_devlink=rpm androidboot.first_stage_console=1 androidboot.hardware.platform=gem5 androidboot.selinux=permissive pvrsrvkm.FabricCoherencyOverride=0";
	/* hardcode rng seed for gem5 */
	rng-seed = "deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef /
		    deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef /
		    deadbeef deadbeef deadbeef deadbeef deadbeef deadbeef";
};

&gpu {
	pre-silicon;
	virtual-platform;
};

&gdmc_ap_non_secure_req_mba_client_2 {
	status = "okay";
};

&gdmc_ap_non_secure_resp_mba_client_3 {
	status = "okay";
};

&gdmc_ap_critical_req_mba_client_4 {
	status = "okay";
};

&gdmc_ap_critical_resp_mba_client_5 {
	status = "okay";
};

&gdmc_ap1_req_mba_client_6 {
	status = "okay";
