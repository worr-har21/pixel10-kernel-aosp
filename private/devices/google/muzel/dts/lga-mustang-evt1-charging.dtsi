&ln8411_dc {
	ln8411,mpp-gpio = <&google_wlc_gpio 2 GPIO_ACTIVE_HIGH>;
	ln8411,wcrx-vol-up-step = <20000>;
	ln8411,wcrx-vol-down-step = <20000>;
	ln8411,max-cal-power = <14400>;
};

