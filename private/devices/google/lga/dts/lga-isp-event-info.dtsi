	/* lwis test device Fake Event Injection definitions */
	test_event_inj: test-event-info_0 {
		irq-reg-space = "test";
		irq-src-reg = <0x0 0x20>;
		irq-reset-reg = <0x0 0x20>;
		irq-mask-reg = <0x0 0x2c>;
		irq-type = "injection";

		irq-events =
			<LWIS_PLATFORM_EVENT_ID_TEST_EVENT_INJ>;
		int-reg-bits =
			<TEST_EVENT_INJ>;
	};

