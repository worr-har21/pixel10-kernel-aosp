		};

		dpu_dsi1_pd: dpu_dsi1_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
			power-domains = <&sswrp_dpu_pd>;
			subdomain-id = <GENPD_LGA_DPU_DSI1_ID>;
		};

		dpu_dp_pd: dpu_dp_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
			power-domains = <&sswrp_dpu_pd>;
			subdomain-id = <GENPD_LGA_DPU_DP_ID>;
			no-auto-resume;
		};

		// lsio_s
		sswrp_lsio_s_pd: sswrp_lsio_s_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_S_ID>;
			on-at-init;
			rpm-always-on;
		};

		lsio_s_cli_gpio_pd: lsio_s_cli_gpio_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_S_ID>;
			power-domains = <&sswrp_lsio_s_pd>;
			subdomain-id = <GENPD_LGA_LSIO_CLI_GPIO_ID>;
			on-at-init;
			rpm-always-on;
			use-smc;
		};

		lsio_s_cli_gpio_irq_safe_pd: lsio_s_cli_gpio_irq_safe_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_LSIO_S_CLI_GPIO_IRQ_SAFE_ID>;
			on-at-init;
			irq-safe;
			use-smc;
		};

		// lsio_n
		sswrp_lsio_n_pd: sswrp_lsio_n_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_N_ID>;
			on-at-init;
		};

		lsio_n_cli_gpio_pd: lsio_n_cli_gpio_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_N_ID>;
			power-domains = <&sswrp_lsio_n_pd>;
			subdomain-id = <GENPD_LGA_LSIO_CLI_GPIO_ID>;
			on-at-init;
		};

		// lsio_e
		sswrp_lsio_e_pd: sswrp_lsio_e_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_E_ID>;
			on-at-init;
			rpm-always-on;
		};

		lsio_e_cli_gpio_pd: lsio_e_cli_gpio_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_LSIO_E_ID>;
			power-domains = <&sswrp_lsio_e_pd>;
			subdomain-id = <GENPD_LGA_LSIO_CLI_GPIO_ID>;
			on-at-init;
			rpm-always-on;
			use-smc;
		};

		lsio_e_cli_gpio_irq_safe_pd: lsio_e_cli_gpio_irq_safe_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_LSIO_E_CLI_GPIO_IRQ_SAFE_ID>;
			on-at-init;
			irq-safe;
			use-smc;
		};

		sswrp_aurora_pd: sswrp_aurora_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_AURORA_ID>;
			no-auto-resume;
		};

		sswrp_ispfe_pd: sswrp_ispfe_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_ISPFE_ID>;
			no-auto-resume;
		};

		ispfe_pipe_pd: ispfe_pipe_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_ISPFE_ID>;
			power-domains = <&sswrp_ispfe_pd>;
			subdomain-id = <GENPD_LGA_ISPFE_PIPE_ID>;
			no-auto-resume;
		};

		ispfe_csis_pd: ispfe_csis_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_ISPFE_ID>;
			power-domains = <&sswrp_ispfe_pd>;
			subdomain-id = <GENPD_LGA_ISPFE_CSIS_ID>;
			no-auto-resume;
		};

		// ispbe
		sswrp_ispbe_pd: sswrp_ispbe_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_ISPBE_ID>;
			no-auto-resume;
		};

		// gsw
		sswrp_gsw_pd: sswrp_gsw_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_GSW_ID>;
			no-auto-resume;
		};

		// eh
		sswrp_eh_pd: sswrp_eh_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_EH_ID>;
		};

		// g2d
		sswrp_g2d_pd: sswrp_g2d_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_G2D_ID>;
			no-auto-resume;
		};

		g2d_core_pd: g2d_core_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_G2D_ID>;
			power-domains = <&sswrp_g2d_pd>;
			subdomain-id = <GENPD_LGA_G2D_CORE_ID>;
			no-auto-resume;
		};

		// codec_3p
		sswrp_codec_3p_pd: sswrp_codec_3p_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_CODEC_3P_ID>;
		};

		// gpdma
		sswrp_gpdma_pd: sswrp_gpdma_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_GPDMA_ID>;
			on-at-init;
			no-auto-resume;
		};

		// aoc
		sswrp_aoc_pd: sswrp_aoc_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_AOC_ID>;
			on-at-init;
		};

		aoc_core_pd: aoc_core_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_AOC_ID>;
			power-domains = <&sswrp_aoc_pd>;
			subdomain-id = <GENPD_LGA_AOC_CORE_ID>;
			on-at-init;
			no-auto-resume;
		};

		// tpu
		sswrp_tpu_pd: sswrp_tpu_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_TPU_ID>;
			active-wakeup;
			no-auto-resume;
		};
	};

	powerdashboard: powerdashboard {
		compatible = "google,power-dashboard";
		mba-dest-channel = <MBOX_DEST_CHAN_POWERDASHBOARD>;
		mboxes = <&goog_mba_cpm_iface>;
		sampling-rate-us = <100000>;
	};

	cpm_rst: cpm_rst {
		compatible = "google,cpm-rst";
		mboxes = <&goog_mba_cpm_iface>;

		hsion_resets: hsion_resets {
			#reset-cells = <1>;
			lpcm-id = <LPCM_HSIO_N>;
			reset-num = <HSION_RST_NUMBER>;
		};

		hsios_resets: hsios_resets {
			#reset-cells = <1>;
			lpcm-id = <LPCM_HSIO_S>;
			reset-num = <HSIOS_RST_NUMBER>;
		};

		lsios_resets: lsios_resets {
			#reset-cells = <1>;
			lpcm-id = <LPCM_LSIO_S>;
			reset-num = <LSIOS_RST_NUMBER>;
		};

		lsion_resets: lsion_resets {
			#reset-cells = <1>;
			lpcm-id = <LPCM_LSIO_N>;
			reset-num = <LSION_RST_NUMBER>;
		};

		lsioe_resets: lsioe_resets {
			#reset-cells = <1>;
			lpcm-id = <LPCM_LSIO_E>;
			reset-num = <LSIOE_RST_NUMBER>;
		};
	};

	otp_cpm_shadow_syscon: otp_cpm_shadow_syscon@53d1000{
		compatible = "google,otp-cpm-shadow-global", "syscon";
		reg = <0x0 0x53d1000 0x0 0x1000>;
	};

	otp_bmsm_shadow_syscon: otp_bmsm_shadow_syscon@de26000{
		compatible = "google,otp-bmsm-shadow-global", "syscon";
		reg = <0x0 0xde26000 0x0 0x4000>;
	};

	otp_sswrp_gpcm_top_csr_syscon: otp_sswrp_gpcm_top_csr_syscon@3441f000{
		compatible = "google,otp-sswrp-gpcm-top-csr-global", "syscon";
		reg = <0x0 0x3441f000 0x0 0x1000>;
	};

	goog_chip_info: goog_chip_info {
		compatible = "google,chip-info";

		ids_table: ids_table {
			compatible = "google,lga_a0_ids";
			google,syscon-phandle = <&otp_cpm_shadow_syscon 0>;
			feature-name = "IDS table";
			translator = "ids-translator";
		};

		dvfs_table: dvfs_table {
			compatible = "google,lga_a0_dvfs";
			google,syscon-phandle = <&otp_cpm_shadow_syscon 0>;
			feature-name = "DVFS table";
			translator = "dvfs-translator";
		};

		hw_feature_table: hw_feature_table {
			compatible = "google,lga_a0_hw_feature";
			google,syscon-phandle = <&otp_cpm_shadow_syscon 0>;
			feature-name = "HW feature table";
		};

		device_table: device_table {
			compatible = "google,lga_a0_ptde";
			google,syscon-phandle = <&otp_cpm_shadow_syscon 0>;
			feature-name = "Device table";
			device-table;
			visible-in-prod;
		};

		serial: serial {
			compatible = "google,lga_a0_serial";
			google,syscon-phandle = <&otp_bmsm_shadow_syscon 0>;
			feature-name = "Serial table";
			private;
			serial-codes;
		};

		gpcm_asic_id: gpcm_asic_id {
			compatible = "google,lga_a0_gpcm_asic_id";
			google,syscon-phandle = <&otp_sswrp_gpcm_top_csr_syscon 0>;
			feature-name = "GPCM ASIC ID";
			translator = "asic-id-translator";
			visible-in-prod;
		};

		ap_rom_patch_ver: ap_rom_patch_ver {
			compatible = "google,lga_a0_ap_rom_patch_ver";
			google,syscon-phandle = <&otp_bmsm_shadow_syscon 0>;
			feature-name = "AP ROM patch version";
			visible-in-prod;
		};

		lcs: lcs {
			compatible = "google,lga_a0_lcs";
			google,syscon-phandle = <&otp_bmsm_shadow_syscon 0>;
			feature-name = "LCS";
			lcs-state;
			private;
		};
	};

	debug_kinfo: debug_kinfo {
		compatible = "google,debug-kinfo";
		memory-region = <&debug_kinfo_reserved>;
	};

	pixel_debug_kinfo: pixel_debug_kinfo {
		compatible = "google,pixel-debug-kinfo";
		memory-region = <&debug_kinfo_reserved>;
	};

	boot-metrics {
		compatible = "google,boot-metrics";

		reg = <0x0 0x0543d000 0x0 0x00001000>;
		reg-names = "ns_sram_base";
		offset = <0xf80>;
	};

	pixel_reboot: pixel_reboot {
		compatible = "google,pixel-reboot-v3";
	};

	boot_diary: boot_diary {
		compatible = "google,boot-diary";
		memory-address = <0x0543e000>;
	};

	gs_debug_test: gs_debug_test {
		compatible = "google,gs-debug-test";
		reg = <0x0 0x053e6000 0x0 0x00001000>;
		reg-names = "cpm_grm_base";
		cpm_sw_crst_ctrl_offset = <0x38>;
		nr_cpu = <0x8>;
		nr_little_cpu = <0x2>;
		nr_mid_cpu = <0x3>;
		nr_big_cpu = <0x3>;
		little_cpu_start = <0x0>;
		mid_cpu_start = <0x2>;
		big_cpu_start = <0x5>;
	};

	keydebug {
		compatible = "keydebug";
		key_down_delay = <6000>;
		keys_down = <116 115>;
		dbg_fn_delay = <2000>;
	};

	cap_sysfs {
		compatible = "google,cap-sysfs";

		idle_pm_stats_regions: idle_pm_stats_regions {
			cap_statsbuf: cap_statsbuf@21911008 {
				reg = <0 0x21911008 0 0x0140>;
				states = <C3_CLUSTER0 C3_CLUSTER1 C3_CLUSTER2 C4 S3>;
				states-verbose = "C3 - Cluster 0",
						 "C3 - Cluster 1",
						 "C3 - Cluster 2",
						 "C4",
						 "S3";
			};

			tfa_cpu_stats: tfa_cpu_stats@8b20f000 {
				reg = <0 0x8b20f000 0 0x1000>;
				states = <C2_CORE0>,
						<C2_CORE1>,
						<C2_CORE2>,
						<C2_CORE3>,
						<C2_CORE4>,
						<C2_CORE5>,
						<C2_CORE6>,
						<C2_CORE7>;
				states-verbose = "C2 - Core 0",
						 "C2 - Core 1",
						 "C2 - Core 2",
						 "C2 - Core 3",
						 "C2 - Core 4",
						 "C2 - Core 5",
						 "C2 - Core 6",
						 "C2 - Core 7";
			};
		};

		dvfs_stats_regions: dvfs_stats_regions {
			cap_dvfs_stats: cap_dvfs_stats@21911148 {
				reg = <0 0x21911148 0 0x0db0>;
				rails = <CLK_LIT CLK_DSU CLK_BCI CLK_MID0 CLK_MID1 CLK_BIG>;
				rails-verbose = "clk_lit",
						"clk_dsu",
						"clk_bci",
						"clk_mid0",
						"clk_mid1",
						"clk_big";
			};
		};

		aging_clc_stats_regions: aging_clc_stats_regions {
			cap_aging_clc_stats: cap_aging_clc_stats@21911ea8 {
				reg = <0 0x21911ef8 0 0x0030>;
				rails = <RAIL_VDD_CPU0 RAIL_VDD_CPU1 RAIL_VDD_CPU2>;
				rails-verbose = "rail_vdd_cpu0",
						"rail_vdd_cpu1",
						"rail_vdd_cpu2";
			};
		};
	};

	arm_pmu-cpu0-6 {
		compatible = "arm,armv8-pmuv3";
		interrupts = <GIC_PPI 7 (GIC_CPU_MASK_RAW(0x3f) | IRQ_TYPE_LEVEL_HIGH)
			      &ppi_cluster0>;
	};

	arm-pmu-cpu7 {
		compatible = "arm,cortex-x4-pmu";
		interrupts = <GIC_PPI 7 (GIC_CPU_MASK_RAW(0x80) | IRQ_TYPE_LEVEL_HIGH)
			      &ppi_cluster1>;
	};

	dsu-pmu {
		compatible = "arm,dsu-pmu";
		interrupts = <GIC_SPI SSWRP_APC_NCLUSTERPMUIRQ IRQ_TYPE_LEVEL_HIGH 0>;
		cpus = <&hayes_0>, <&hayes_1>, <&hunter_0>, <&hunter_1>, <&hunter_2>, <&hunter_3>,
		       <&hunter_4>, <&hunterelp_0>;
	};

	ip_idle_notifier {
		compatible = "google,ip-idle-notifier";
		mba-dest-channel = <MBOX_DEST_CHAN_SSRAM_REQUEST>;
		mboxes = <&goog_mba_cpm_iface>;
	};

	odm: odm {
		compatible = "simple-bus";
		ranges;
	};

	google_mitigation: google-mitigation {
		mba-dest-service-id = <MBOX_SERVICE_ID_BCL>;
		mba-pmic-dest-channel = <MBOX_DEST_CHAN_DA9188_REGULATOR>;
	};

	cpm_irq: cpm_irq {
		compatible = "google,cpm-irq";
		mboxes = <&goog_mba_cpm_iface>;

		interrupt-controller;
		#interrupt-cells = <2>;

		mba-dest-channel = <MBOX_SERVICE_ID_CPM_IRQ>;
		mba-dest-service-id = <MBOX_DEST_CHAN_CPM_IRQ>;
	};

	dvfs_helper: dvfs_helper {
		compatible = "google,dvfs-helper";
		mboxes = <&goog_mba_cpm_iface>;
	};

	cpu_lpm_stats: cpu_lpm_stats {
		compatible = "google,cpu-lpm-stats";

		power-domain-cpu0 {
			power-domains = <&CPU_PD0>;
			power-state = <C2_CORE0>;
		};

		power-domain-cpu1 {
			power-domains = <&CPU_PD1>;
			power-state = <C2_CORE1>;
		};

		power-domain-cpu2 {
			power-domains = <&CPU_PD2>;
			power-state = <C2_CORE2>;
		};

		power-domain-cpu3 {
			power-domains = <&CPU_PD3>;
			power-state = <C2_CORE3>;
		};

		power-domain-cpu4 {
			power-domains = <&CPU_PD4>;
			power-state = <C2_CORE4>;
		};

		power-domain-cpu5 {
			power-domains = <&CPU_PD5>;
			power-state = <C2_CORE5>;
		};

		power-domain-cpu6 {
			power-domains = <&CPU_PD6>;
			power-state = <C2_CORE6>;
		};

		power-domain-cpu7 {
			power-domains = <&CPU_PD7>;
			power-state = <C2_CORE7>;
		};

		power-domain-top-cluster {
			power-domains = <&CPU_TOP_CL>;
			power-state = <C4>;
		};

		power-domain-cluster-1 {
			power-domains = <&CPUCL1>;
			power-state = <C3_CLUSTER1>;
		};

		power-domain-cluster-2 {
			power-domains = <&CPUCL2>;
			power-state = <C3_CLUSTER2>;
		};
	};

	cpu_cluster1_cstate_ctrl {
		compatible = "google,cstate-ctrl";
		power-domains = <&CPUCL1>;
	};

	cpu_cluster2_cstate_ctrl {
		compatible = "google,cstate-ctrl";
		power-domains = <&CPUCL2>;
	};

	cpu_c4_cstate_ctrl {
		compatible = "google,cstate-ctrl";
		power-domains = <&CPU_TOP_CL>;
		debugfs-name = "c4";
	};
};
