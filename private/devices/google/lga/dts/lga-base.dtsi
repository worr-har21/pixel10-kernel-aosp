	edac: edac {
		compatible = "google,edac";
		// TODO(b/291686880): restore the node
		status = "disabled";
		interrupts = <GIC_SPI 47 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 48 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 49 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 50 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 51 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 52 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 53 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 54 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 39 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 40 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 41 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 42 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 43 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 44 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 45 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 46 IRQ_TYPE_LEVEL_HIGH 0>;
		interrupt-names = "ERI0", "ERI1", "ERI2", "ERI3",
				  "ERI4", "ERI5", "ERI6", "ERI7",
				  "FHI0", "FHI1", "FHI2", "FHI3",
				  "FHI4", "FHI5", "FHI6", "FHI7";
	};

	power_controller: power_controller {
		compatible = "google,lga-power-controller";
		mboxes = <&goog_mba_cpm_iface>;
		#address-cells = <0x00000002>;
		#size-cells = <0x00000002>;
		ranges;

		sswrp_gpu_pd: sswrp_gpu_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_GPU_ID>;
		};

		gpu_core_logic_pd: gpu_core_logic_pd@34809400 {
			reg = <0 0x3480a000 0 0x4>,
			      <0 0x34826000 0 0x400>,
			      <0 0x34820a30 0 0x10>,
			      <0 0x34855c40 0 0x10>;
			reg-names = "gpu_control", "pvtc", "pvtc_pwroff", "dts";
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_GPU_ID>;
			power-domains = <&sswrp_gpu_pd>;
			subdomain-id = <GENPD_LGA_GPU_CORE_LOGIC_ID>;
		};

		// hsio_n
		sswrp_hsio_n_pd: sswrp_hsio_n_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			on-at-init;
		};

		hsio_n_usb_pd: hsio_n_usb_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&sswrp_hsio_n_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_USB_ID>;
			on-at-init;
			active-wakeup;
		};

		hsio_n_usb_psw_pd: hsio_n_usb_psw_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&hsio_n_usb_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_USB_PSW_ID>;
			on-at-init;
			active-wakeup;
		};

		hsio_n_pcie_pd: hsio_n_pcie_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&sswrp_hsio_n_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_PCIE_ID>;
			active-wakeup;
		};

		hsio_n_ebu_pd: hsio_n_ebu_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&hsio_n_usb_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_EBU_ID>;
		};

		hsio_n_ebu_core_pd: hsio_n_ebu_core_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&hsio_n_ebu_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_EBU_CORE_ID>;
		};

		hsio_n_dp_pd: hsio_n_dp_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_N_ID>;
			power-domains = <&hsio_n_usb_psw_pd>;
			subdomain-id = <GENPD_LGA_HSIO_N_DP_ID>;
			no-auto-resume;
		};

		// hsio_s
		sswrp_hsio_s_pd: sswrp_hsio_s_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_S_ID>;
			on-at-init;
			rpm-always-on;
		};

		hsio_s_ufs_prep_pd: hsio_s_ufs_prep_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_S_ID>;
			power-domains = <&sswrp_hsio_s_pd>;
			subdomain-id = <GENPD_HSIO_S_UFS_PREP_ID>;
			on-at-init;
		};

		hsio_s_ufs_pd: hsio_s_ufs_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_S_ID>;
			power-domains = <&hsio_s_ufs_prep_pd>;
			subdomain-id = <GENPD_LGA_HSIO_S_UFS_ID>;
			on-at-init;
			rpm-always-on;
		};

		hsio_s_pcie_pd: hsio_s_pcie_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_S_ID>;
			power-domains = <&sswrp_hsio_s_pd>;
			subdomain-id = <GENPD_LGA_HSIO_S_PCIE_ID>;
		};

		hsio_s_sd_pd: hsio_s_sd_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_HSIO_S_ID>;
			power-domains = <&hsio_s_ufs_pd>;
			subdomain-id = <GENPD_LGA_HSIO_S_SD_ID>;
		};

		// dpu
		sswrp_dpu_pd: sswrp_dpu_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
		};

		dpu_fe0_pd: dpu_fe0_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
			power-domains = <&dpu_dsi0_pd>;
			subdomain-id = <GENPD_LGA_DPU_FE0_ID>;
		};

		dpu_fe1_pd: dpu_fe1_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
			power-domains = <&dpu_fe0_pd>;
			subdomain-id = <GENPD_LGA_DPU_FE1_ID>;
		};

		dpu_dsi0_pd: dpu_dsi0_pd {
			#power-domain-cells = <0>;
			sswrp-id = <GENPD_LGA_SSWRP_DPU_ID>;
