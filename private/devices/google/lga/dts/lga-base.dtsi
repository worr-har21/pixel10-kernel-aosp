	gpdma3: gpdma_wrapper@3b9c0000 {
		compatible = "google,gpdma";
		reg = <0 0x3b9d3000 0 0x80>,
			  <0 0x3b9c10c0 0 0x90>;
		reg-names = "req_ack_csr", "axuser_csr";
