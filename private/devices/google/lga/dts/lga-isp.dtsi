			<&flow_sync_y_gl0_c_header_itv_1_err_irq>;

		/* Thread priority */
			transaction-thread-priority = <99>;
	};

	lwis_slc: lwis_slc@51c {
		compatible = "google,lwis-slc-device";
		power-domains =
			<&sswrp_ispbe_pd>,
			<&sswrp_gsw_pd>;

		/* Device node name */
		node-name = "slc";

		/* Register space */
		reg =
			<0x0 0x3E400000 0x0 0x400000>,		/* ISPBE */
			<0x0 0x3EC00000 0x0 0x400000>;		/* ISPGSW */
		reg-names =
			"isp_be",
			"isp_gsw";

		/* SLC partitions */
		pt_id =
			"isp_p0",
			"isp_p1",
			"isp_p2",
			"isp_p3",
			"isp_p4",
			"isp_p5";

		pt_size = <480 720 890 900 950 1865>;
	};
};
