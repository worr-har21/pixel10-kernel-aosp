		lwis_gsw_pdma: lwis_gsw_pdma@230000 {
			compatible = "google,lwis-ioreg-device";
			power-domains = <&sswrp_gsw_pd>;

			/* Device node name */
			node-name = "gsw-pdma";

			/* Register space */
			reg = <0x0 0x0 0x24D100>;

			/* Valid ranges */
			reg-valid-ranges =
				/* GIA */
				<0x0 0x1d0000 0x10>,
				/* PDMA core */
				<0x0 0x229000 0x24100>,
				/* IP cores */
				<0x0 0x1D8000 0x20018>,
				<0x0 0x200000 0x2801C>;

			reg-names = "isp_gsw";

			device-group = <3>;

