// TODO(b/291686880): Migrate to lga
#include <dt-bindings/interconnect/google,rdo.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/irq-gia-google-lga.h>

#include "lga-devfreq.dtsi"
#include "lga-isp-event-info.dtsi"

/ {
	lwis_top: lwis_top {
		compatible = "google,lwis-top-device";

		/* Device node name */
		node-name = "top";

		/* Thread priority */
		transaction-thread-priority = <99>;
	};

	lwis_dpm: lwis_dpm {
		compatible = "google,lwis-dpm-device";

		/* Device node name */
		node-name = "dpm";

		clocks =
			<&ispfe_pf_state_clk>,
			<&ispbe_pf_state_clk>,
			<&gsw_pf_state_clk>;
		clock-names =
			"ispfe_pclk",
			"ispbe_pclk",
			"gsw_pclk";
	};

	lwis_test: lwis_test@0 {
		compatible = "google,lwis-test-device";

		/* Device node name */
		node-name = "test";

		/* Register space */
		reg = <0x0 0x0 0x0 0x20>;
		reg-names = "test";
		interrupt-names = "test_event_inj";
		interrupt-event-infos = <&test_event_inj>;
	};

	sswrp_ispfe: sswrp_ispfe@F000000 {
		compatible = "simple-bus";
		#address-cells = <2>;
		#size-cells = <1>;
		ranges = <0x0 0x0 0x0 0x0f000000 0x1000000>;

		lwis_isp_fe: lwis_isp_fe@0 {
			compatible = "google,lwis-ioreg-device";
			google,qos_box_dev =
				<&qos_box_ispfe_1>,
				<&qos_box_ispfe_2>,
				<&qos_box_ispfe_3>;
			google,qos_box_dev_names =
				"ispfe_data1",
				"ispfe_data2",
				"ispfe_data3";
			power-domains =
				<&ispfe_csis_pd>,
				<&ispfe_pipe_pd>;

			/* Device node name */
			node-name = "isp-fe";

			/* Register space */
			reg =
				<0x0 0x000000 0x1000000>, /* ISPFE */
				<0x0 0x800000 0x0200000>; /* CSIS PHY LINK */
			reg-names =
				"isp-fe",
				"csis-phy-link";

			reg-valid-ranges =
				<0x0 0x9000 0x2C078>, /* LPCM */
				<0x0 0x61000 0xE20000>, /* ISPFE */
				<0x1 0x0 0xFE100>; /* CSIS PHY LINK */

			interrupts-extended =
				<&ispfe_level_aggr_3_intr 21>,
				<&ispfe_level_aggr_3_intr 21>,
				<&ispfe_level_aggr_3_intr 21>,
				<&ispfe_level_aggr_3_intr 21>,
