#include <dt-bindings/lpcm/clock.h>

/ {
	cpm_clk: cpm_clk {
		compatible = "google,cpm-clk";
		mboxes = <&goog_mba_cpm_iface>;

		power-domains = <&sswrp_dpu_pd>, <&sswrp_lsio_s_pd>, <&sswrp_lsio_e_pd>,
				<&sswrp_lsio_n_pd>, <&sswrp_hsio_n_pd>, <&sswrp_hsio_s_pd>;

		/* lsios */
		lsios_mclk0_clk: lsios_mclk0_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK0_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk1_clk: lsios_mclk1_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK1_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk2_clk: lsios_mclk2_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK2_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk3_clk: lsios_mclk3_clk {
