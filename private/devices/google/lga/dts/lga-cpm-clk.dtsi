			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK7_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_gpio_clk: lsios_gpio_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_GPIO_CLK>;
			use-smc;
