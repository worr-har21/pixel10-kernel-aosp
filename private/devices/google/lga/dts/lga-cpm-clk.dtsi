			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK4_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk5_clk: lsios_mclk5_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK5_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk6_clk: lsios_mclk6_clk {
			#clock-cells = <0>;
			lpcm-id = <LPCM_LSIO_S>;
			clock-id = <LSIOS_MCLK6_CLK>;
			rates = /bits/ 64 <24576000>;
		};

		lsios_mclk7_clk: lsios_mclk7_clk {
