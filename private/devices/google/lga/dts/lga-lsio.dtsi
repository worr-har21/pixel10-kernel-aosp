	lsios_cli0_i2c: i2c@3bf01000 {
		compatible = "google,i2c";
		reg = <0x0 0x3bf01000 0x0 0x100>;
		interrupts-extended = <&lsios_level_aggr_4_intr LSIOS_GIA_LEVEL_AGGR_4_IP_TOP_CLI0_CLI_INT>;
		clocks = <&lsios_cli0_i2c_clk>,
		         <&lsios_cli0_cfg_clk>;
		clock-names = "ic_clk", "pclk";
		resets = <&lsios_resets LSIOS_CLI0_I2C_IC_CFG_RST>;
		reset-names = "ic_rst";
		power-domains = <&lsio_s_cli_gpio_pd>;
		pinctrl-0 = <&cli0_2_wire_func>, <&cli0_i2c_conf>;
		pinctrl-1 = <&cli0_2_wire_sleep>;
		pinctrl-2 = <&cli0_i2c_conf>;
		pinctrl-names = "default", "sleep", "cli";
		status = "disabled";
	};

