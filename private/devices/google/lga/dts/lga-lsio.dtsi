	lsion_cli17_int0_i2c: i2c@db01000 {
		compatible = "google,i2c";
		reg = <0x0 0xdb01000 0x0 0x100>;
		interrupts-extended = <&lsion_level_aggr_4_intr LSION_GIA_LEVEL_AGGR_4_IP_TOP_CLI_INT0_CLI_INT>;
		clocks = <&lsion_cli_int0_i2c_clk>,
		         <&lsion_cli_int0_cfg_clk>;
		clock-names = "ic_clk", "pclk";
		resets = <&lsion_resets LSION_CLI17_INT0_I2C_IC_CFG_RST>;
		reset-names = "ic_rst";
		/* Add identical sleep state other wise pinctrl select state
		 * would be NOP after first time.
		 * TODO: b/315093578, add missing pinctrl settings
		 */
		power-domains = <&lsio_n_cli_gpio_pd>;
		pinctrl-0 = <&cli17_int0_2_wire_func>, <&cli_int0_i2c_conf>;
		pinctrl-1 = <&cli17_int0_2_wire_sleep>;
		pinctrl-2 = <&cli_int0_i2c_conf>;
		pinctrl-names = "default", "sleep", "cli";
		status = "disabled";
	};

