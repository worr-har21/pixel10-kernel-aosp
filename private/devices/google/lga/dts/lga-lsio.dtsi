#if defined(TINY_CFG)
	clk_200mhz: clk_200mhz {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <200000000>;
	};
#endif

	lsion_cli16_uart: uart@db61000 {
		compatible = "goog,goog-dw-apb-uart";
		reg = <0x0 0xdb62000 0x0 0x100>;
		reg-shift = <2>;
		reg-io-width = <4>;
		/*
		 * Interrupt is direct routed to GIC and also aggregated
		 * via GIA under lsion_ap_other_intr. It is preferred to
		 * use direct interrupt to avoid dependency with gia-driver
		 */
		interrupts = <GIC_SPI SSWRP_LSION_LSION_CLI16_INTR IRQ_TYPE_LEVEL_HIGH 0>;
		/* TINY_CFG should boot to shell without need for clk/rst/pinctrl/pd drivers */
#if defined(TINY_CFG)
		clocks = <&clk_200mhz>;
		clock-names = "baudclk";
#else
		clocks = <&lsion_cli16_uart_clk>,
			 <&lsion_cli16_cfg_clk>;
		clock-names = "baudclk", "apb_pclk";
		resets = <&lsion_resets LSION_CLI16_UART_IC_CFG_RST>;
		reset-names = "s_rst_n";
		pinctrl-0 = <&cli16_uart_conf>;
		pinctrl-1 = <>;
		pinctrl-2 = <&cli16_uart_conf>;
		pinctrl-names = "default", "sleep", "cli";
		power-domains = <&lsio_n_cli_gpio_pd>;
#endif
		status = "disabled";
	};

