		};

		aoc_i3c1_pins: aoc-i3c1-pins {
			pins =  "XAOC_I3C1_SCL",
				"XAOC_I3C1_SDA";
			function = "aoc_i3c1";
			bias-disable;
		};

		aoc_i2c2_pins: aoc-i2c2-pins {
			pins =  "XAOC_I2C2_SCL",
				"XAOC_I2C2_SDA";
			function = "aoc_i2c2";
			bias-disable;
		};

		aoc_i2c4_pins: aoc-i2c4-pins {
			pins =  "XAOC_I2C4_SCL",
				"XAOC_I2C4_SDA";
			function = "aoc_i2c4";
			bias-disable;
		};

		aoc_tdm1_out_pins: aoc-tdm1-out-pins {
			pins =  "XAOC_TDM1_BCLK",
				"XAOC_TDM1_WS",
				"XAOC_TDM1_SDO";
			function = "aoc_tdm1";
			drive-strength = <2>;
			output-enable;
			bias-disable;
		};

		aoc_tdm1_in_pins: aoc-tdm1-in-pins {
			pins =  "XAOC_TDM1_SDI";
			function = "aoc_tdm1";
			bias-pull-down;
			input-enable;
			output-disable;
		};

		aoc_pdm_pins: aoc-pdm-pins {
			pins =  "XAOC_PDM0_MIC_IN";
			function = "aoc_pdm";
			bias-pull-down;
			input-enable;
			output-disable;
		};

		aoc_pdm1_pins: aoc-pdm1-pins {
			pins =  "XAOC_PDM1_MIC_IN";
			function = "aoc_pdm1";
			bias-pull-down;
			input-enable;
			output-disable;
		};

		aoc_pdm2_pins: aoc-pdm2-pins {
			pins =  "XAOC_PDM2_MIC_IN";
			function = "aoc_pdm2";
			bias-pull-down;
			input-enable;
			output-disable;
		};

		aoc_pdm3_pins: aoc-pdm3-pins {
			pins =  "XAOC_PDM3_MIC_IN";
			function = "aoc_pdm3";
			bias-pull-down;
			input-enable;
			output-disable;
		};
	};

	gdmc_pinctrl: pinctrl@6480000 {
		compatible = "google,lga-gdmc-pinctrl";
		reg = <0 0x6480000 0 0x15000>;

		gpio-controller;
		gpio-ranges = <&gdmc_pinctrl 0 0 21>;
		#gpio-cells = <2>;
		gpio-reserved-ranges = <6 7>;

		sswrp-wakeup-capable;

		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts = <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_62_662 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_UART0_RXD
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_61_661 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_UART0_TXD
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_60_660 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_IN_DEBUG_1
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_59_659 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_DEBUG_DEFAULT_1
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_58_658 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_CTI_0
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_57_657 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_IN_DEBUG_0
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_56_656 IRQ_TYPE_LEVEL_HIGH 0>, //XGDMC_DEBUG_DEFAULT_0
			     <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_55_655 IRQ_TYPE_LEVEL_HIGH 0>; //XGDMC_CTI_1

		irq-pad-mapping = <XGDMC_UART0_RXD>,
				  <XGDMC_UART0_TXD>,
				  <XGDMC_IN_DEBUG_1>,
				  <XGDMC_DEBUG_DEFAULT_1>,
				  <XGDMC_CTI_0>,
				  <XGDMC_IN_DEBUG_0>,
				  <XGDMC_DEBUG_DEFAULT_0>,
				  <XGDMC_CTI_1>;

		// TODO: Clock requirement
	};

	dpu_pinctrl: pinctrl@EC7E000 {
		compatible = "google,lga-dpu-pinctrl";
		// TODO(b/297977781): Enable once needed/verified.
		status = "disabled";
		reg = <0 0xEC7E000 0 0x2000>;

		gpio-controller;
		gpio-ranges = <&dpu_pinctrl 0 0 2>;
		#gpio-cells = <2>;

		power-domains = <&sswrp_dpu_pd>;
		power-domain-names = "csr_access_pd";
		// TODO: Clock
	};
};
