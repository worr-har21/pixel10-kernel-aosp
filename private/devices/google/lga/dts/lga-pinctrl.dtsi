	lsios_pinctrl: pinctrl@3BE00000 {
		compatible = "google,lga-lsios-pinctrl";
		reg = <0 0x3BE00000 0 0x37000>;

		gpio-controller;
		gpio-ranges = <&lsios_pinctrl 0 0 55>;
		#gpio-cells = <2>;
		gpio-reserved-ranges = <54 1>;

		clocks = <&lsios_gpio_clk>;
		clock-names = "gpio_clk";

		power-domains = <&lsio_s_cli_gpio_pd>,<&sswrp_lsio_s_pd>;
		power-domain-names="csr_access_pd","pad_function_pd";

