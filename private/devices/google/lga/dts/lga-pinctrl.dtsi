	hsios_stby_pinctrl: pinctrl@3C568000 {
		compatible = "google,lga-hsios-stby-pinctrl";

		reg = <0 0x3C568000 0 0x2000>;

		hsios_stby_ufs_refclk: hsios_stby_ufs_refclk {
			pins = "XHSIOS_UFS_REFCLK";
			function = "hsios_stby_ufs";
			// TODO(b/294685941): Drive strength should to be programmed based on value read from OTP
			// TODO(b/294685941): Slew should be programmed based on otp value
			drive-strength = <0x1>;
			output-enable;
			bias-disable;
		};

		hsios_stby_ufs_refclk_sleep: hsios_stby_ufs_refclk_sleep {
			pins = "XHSIOS_UFS_REFCLK";
			function = "hsios_stby_ufs";
			drive-strength = <0x0>;
			bias-pull-down;
		};
	};

	hsios_pinctrl: pinctrl@3C590000 {
