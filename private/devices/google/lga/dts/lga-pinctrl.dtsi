				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_GPIO3_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_GPIO4_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_UFS_PWR_EN_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_PCIE1_CLKREQN0_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_PCIE1_PERSTN0_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_GPIO5_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_GPIO6_IRQ>,
				<&hsios_multicast_aggr_6_intr HSIO_S_GIA_MULTICAST_AGGR_6_AUX_GPIO_HSIOS_BK_XHSIOS_VSYNC4_IRQ>;

		irq-pad-mapping = <XHSIOS_UFS_RESETB>,
				  <XHSIOS_GPIO7>,
				  <XHSIOS_GPIO8>,
				  <XHSIOS_GPIO0>,
				  <XHSIOS_GPIO1>,
				  <XHSIOS_GPIO2>,
				  <XHSIOS_GPIO3>,
				  <XHSIOS_GPIO4>,
				  <XHSIOS_UFS_PWR_EN>,
				  <XHSIOS_PCIE1_CLKREQN0>,
				  <XHSIOS_PCIE1_PERSTN0>,
				  <XHSIOS_GPIO5>,
				  <XHSIOS_GPIO6>,
				  <XHSIOS_VSYNC4>;

		hsios_pcie1_perst: hsios-pcie1-perst {
			pins = "XHSIOS_PCIE1_PERSTN0";
