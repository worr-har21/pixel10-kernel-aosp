	lsion_pinctrl: pinctrl@DA00000 {
		compatible = "google,lga-lsion-pinctrl";
		reg = <0 0xDA00000 0 0x8000>;

		gpio-controller;
		gpio-ranges = <&lsion_pinctrl 0 0 8>;
		#gpio-cells = <2>;

		clocks = <&lsion_gpio_clk>;
		clock-names = "gpio_clk";

		power-domains = <&lsio_n_cli_gpio_pd>;
		power-domain-names="csr_access_pd";

		runtime-pm-capable;

		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts-extended =
