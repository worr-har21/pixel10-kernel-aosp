/ {
	lsioe_pinctrl: pinctrl@3A200000 {
		compatible = "google,lga-lsioe-pinctrl";
		reg = <0 0x3A200000 0 0x20000>;

		gpio-controller;
		gpio-ranges = <&lsioe_pinctrl 0 0 32>;
		#gpio-cells = <2>;

		clocks = <&lsioe_gpio_clk>;
		clock-names = "gpio_clk";

		power-domains = <&lsio_e_cli_gpio_pd>,<&sswrp_lsio_e_pd>;
		power-domain-names="csr_access_pd","pad_function_pd";

		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts-extended =
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI7_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI7_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI7_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI7_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI8_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI8_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI8_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI8_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI13_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI13_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI13_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI13_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI9_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI9_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI9_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI9_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI10_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI10_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI10_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI10_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI11_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI11_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI11_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI11_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI12_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI12_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI12_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI12_PIN3_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI14_PIN0_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI14_PIN1_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI14_PIN2_IRQ>,
				<&lsioe_level_aggr_0_intr LSIOE_GIA_LEVEL_AGGR_0_AUX_AON_IOBANK_XLSIOE_CLI14_PIN3_IRQ>;
		irq-pad-mapping = <XLSIOE_CLI7_PIN0>,
				  <XLSIOE_CLI7_PIN1>,
				  <XLSIOE_CLI7_PIN2>,
				  <XLSIOE_CLI7_PIN3>,
				  <XLSIOE_CLI8_PIN0>,
				  <XLSIOE_CLI8_PIN1>,
				  <XLSIOE_CLI8_PIN2>,
				  <XLSIOE_CLI8_PIN3>,
				  <XLSIOE_CLI13_PIN0>,
				  <XLSIOE_CLI13_PIN1>,
				  <XLSIOE_CLI13_PIN2>,
				  <XLSIOE_CLI13_PIN3>,
				  <XLSIOE_CLI9_PIN0>,
				  <XLSIOE_CLI9_PIN1>,
				  <XLSIOE_CLI9_PIN2>,
				  <XLSIOE_CLI9_PIN3>,
				  <XLSIOE_CLI10_PIN0>,
				  <XLSIOE_CLI10_PIN1>,
				  <XLSIOE_CLI10_PIN2>,
				  <XLSIOE_CLI10_PIN3>,
				  <XLSIOE_CLI11_PIN0>,
				  <XLSIOE_CLI11_PIN1>,
				  <XLSIOE_CLI11_PIN2>,
				  <XLSIOE_CLI11_PIN3>,
				  <XLSIOE_CLI12_PIN0>,
				  <XLSIOE_CLI12_PIN1>,
				  <XLSIOE_CLI12_PIN2>,
				  <XLSIOE_CLI12_PIN3>,
				  <XLSIOE_CLI14_PIN0>,
				  <XLSIOE_CLI14_PIN1>,
				  <XLSIOE_CLI14_PIN2>,
				  <XLSIOE_CLI14_PIN3>;

		//CLI 7
		cli7_2_wire_func: cli7_2_wire_func {
			pins =  "XLSIOE_CLI7_PIN0",
				"XLSIOE_CLI7_PIN1";
			function = "lsioe_cli7";
			output-disable;
			input-enable;
		};
		cli7_spi_clk_mosi_miso_func: cli7_spi_clk_mosi_miso_func {
			pins =  "XLSIOS_CLI7_PIN0",
				"XLSIOE_CLI7_PIN1",
				"XLSIOE_CLI7_PIN2";
			function = "lsioe_cli7";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli7_spi_cs_gpio_func: cli7_spi_cs_gpio_func {
			pins = "XLSIOE_CLI7_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli7_4_wire_func: cli7_4_wire_func {
			pins =  "XLSIOE_CLI7_PIN0",
				"XLSIOE_CLI7_PIN1",
				"XLSIOE_CLI7_PIN2",
				"XLSIOE_CLI7_PIN3";
			function = "lsioe_cli7";
			output-disable;
			input-enable;
		};
		cli7_2_wire_sleep: cli7_2_wire_sleep {
			pins =  "XLSIOE_CLI7_PIN0",
				"XLSIOE_CLI7_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli7_4_wire_sleep: cli7_4_wire_sleep {
			pins =  "XLSIOE_CLI7_PIN0",
				"XLSIOE_CLI7_PIN1",
				"XLSIOE_CLI7_PIN2",
				"XLSIOE_CLI7_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 8
		cli8_2_wire_func: cli8_2_wire_func {
			pins =  "XLSIOE_CLI8_PIN0",
				"XLSIOE_CLI8_PIN1";
			function = "lsioe_cli8";
			output-disable;
			input-enable;
		};
		cli8_spi_clk_mosi_miso_func: cli8_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI8_PIN0",
				"XLSIOE_CLI8_PIN1",
				"XLSIOE_CLI8_PIN2";
			function = "lsioe_cli8";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli8_spi_cs_gpio_func: cli8_spi_cs_gpio_func {
			pins = "XLSIOE_CLI8_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli8_4_wire_func: cli8_4_wire_func {
			pins =  "XLSIOE_CLI8_PIN0",
				"XLSIOE_CLI8_PIN1",
				"XLSIOE_CLI8_PIN2",
				"XLSIOE_CLI8_PIN3";
			function = "lsioe_cli8";
			output-disable;
			input-enable;
		};
		cli8_2_wire_sleep: cli8_2_wire_sleep {
			pins =  "XLSIOE_CLI8_PIN0",
				"XLSIOE_CLI8_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli8_4_wire_sleep: cli8_4_wire_sleep {
			pins =  "XLSIOE_CLI8_PIN0",
				"XLSIOE_CLI8_PIN1",
				"XLSIOE_CLI8_PIN2",
				"XLSIOE_CLI8_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 9
		cli9_2_wire_func: cli9_2_wire_func {
			pins =  "XLSIOE_CLI9_PIN0",
				"XLSIOE_CLI9_PIN1";
			function = "lsioe_cli9";
			output-disable;
			input-enable;
		};
		cli9_spi_clk_mosi_miso_func: cli9_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI9_PIN0",
				"XLSIOE_CLI9_PIN1",
				"XLSIOE_CLI9_PIN2";
			function = "lsioe_cli9";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli9_spi_cs_gpio_func: cli9_spi_cs_gpio_func {
			pins = "XLSIOE_CLI9_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli9_4_wire_func: cli9_4_wire_func {
			pins =  "XLSIOE_CLI9_PIN0",
				"XLSIOE_CLI9_PIN1",
				"XLSIOE_CLI9_PIN2",
				"XLSIOE_CLI9_PIN3";
			function = "lsioe_cli9";
			output-disable;
			input-enable;
		};
		cli9_2_wire_sleep: cli9_2_wire_sleep {
			pins =  "XLSIOE_CLI9_PIN0",
				"XLSIOE_CLI9_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli9_4_wire_sleep: cli9_4_wire_sleep {
			pins =  "XLSIOE_CLI9_PIN0",
				"XLSIOE_CLI9_PIN1",
				"XLSIOE_CLI9_PIN2",
				"XLSIOE_CLI9_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 10
		cli10_2_wire_func: cli10_2_wire_func {
			pins =  "XLSIOE_CLI10_PIN0",
				"XLSIOE_CLI10_PIN1";
			function = "lsioe_cli10";
			output-disable;
			input-enable;
		};
		cli10_spi_clk_mosi_miso_func: cli10_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI10_PIN0",
				"XLSIOE_CLI10_PIN1",
				"XLSIOE_CLI10_PIN2";
			function = "lsioe_cli10";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli10_spi_cs_gpio_func: cli10_spi_cs_gpio_func {
			pins = "XLSIOE_CLI10_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli10_4_wire_func: cli10_4_wire_func {
			pins =  "XLSIOE_CLI10_PIN0",
				"XLSIOE_CLI10_PIN1",
				"XLSIOE_CLI10_PIN2",
				"XLSIOE_CLI10_PIN3";
			function = "lsioe_cli10";
			output-disable;
			input-enable;
		};
		cli10_2_wire_sleep: cli10_2_wire_sleep {
			pins =  "XLSIOE_CLI10_PIN0",
				"XLSIOE_CLI10_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli10_4_wire_sleep: cli10_4_wire_sleep {
			pins =  "XLSIOE_CLI10_PIN0",
				"XLSIOE_CLI10_PIN1",
				"XLSIOE_CLI10_PIN2",
				"XLSIOE_CLI10_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 11
		cli11_2_wire_func: cli11_2_wire_func {
			pins =  "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1";
			function = "lsioe_cli11";
			output-disable;
			input-enable;
		};
		cli11_spi_clk_mosi_miso_func: cli11_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1",
				"XLSIOE_CLI11_PIN2";
			function = "lsioe_cli11";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli11_spi_cs_gpio_func: cli11_spi_cs_gpio_func {
			pins = "XLSIOE_CLI11_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli11_4_wire_func: cli11_4_wire_func {
			pins =  "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1",
				"XLSIOE_CLI11_PIN2",
				"XLSIOE_CLI11_PIN3";
			function = "lsioe_cli11";
			output-disable;
			input-enable;
		};
		cli11_2_wire_sleep: cli11_2_wire_sleep {
			pins =  "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli11_4_wire_sleep: cli11_4_wire_sleep {
			pins =  "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1",
				"XLSIOE_CLI11_PIN2",
				"XLSIOE_CLI11_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};
		cli11_2_wire_spmi_func: cli11_2_wire_spmi_func {
			pins = "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1";
			function = "lsioe_spmi0";
			output-enable;
		};
		cli11_2_wire_spmi_sleep: cli11_2_wire_spmi_sleep {
			pins = "XLSIOE_CLI11_PIN0",
				"XLSIOE_CLI11_PIN1";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 12
		cli12_2_wire_func: cli12_2_wire_func {
			pins =  "XLSIOE_CLI12_PIN0",
				"XLSIOE_CLI12_PIN1";
			function = "lsioe_cli12";
			output-disable;
			input-enable;
		};
		cli12_spi_clk_mosi_miso_func: cli12_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI12_PIN0",
				"XLSIOE_CLI12_PIN1",
				"XLSIOE_CLI12_PIN2";
			function = "lsioe_cli12";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli12_spi_cs_gpio_func: cli12_spi_cs_gpio_func {
			pins = "XLSIOE_CLI12_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli12_4_wire_func: cli12_4_wire_func {
			pins =  "XLSIOE_CLI12_PIN0",
				"XLSIOE_CLI12_PIN1",
				"XLSIOE_CLI12_PIN2",
				"XLSIOE_CLI12_PIN3";
			function = "lsioe_cli12";
			output-disable;
			input-enable;
		};
		cli12_2_wire_sleep: cli12_2_wire_sleep {
			pins =  "XLSIOE_CLI12_PIN0",
				"XLSIOE_CLI12_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli12_4_wire_sleep: cli12_4_wire_sleep {
			pins =  "XLSIOE_CLI12_PIN0",
				"XLSIOE_CLI12_PIN1",
				"XLSIOE_CLI12_PIN2",
				"XLSIOE_CLI12_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 13
		cli13_2_wire_func: cli13_2_wire_func {
			pins =  "XLSIOE_CLI13_PIN0",
				"XLSIOE_CLI13_PIN1";
			function = "lsioe_cli13";
			output-disable;
			input-enable;
		};
		cli13_spi_clk_mosi_miso_func: cli13_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI13_PIN0",
				"XLSIOE_CLI13_PIN1",
				"XLSIOE_CLI13_PIN2";
			function = "lsioe_cli13";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli13_spi_cs_gpio_func: cli13_spi_cs_gpio_func {
			pins = "XLSIOE_CLI13_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli13_4_wire_func: cli13_4_wire_func {
			pins =  "XLSIOE_CLI13_PIN0",
				"XLSIOE_CLI13_PIN1",
				"XLSIOE_CLI13_PIN2",
				"XLSIOE_CLI13_PIN3";
			function = "lsioe_cli13";
			output-disable;
			input-enable;
		};
		cli13_2_wire_sleep: cli13_2_wire_sleep {
			pins =  "XLSIOE_CLI13_PIN0",
				"XLSIOE_CLI13_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli13_4_wire_sleep: cli13_4_wire_sleep {
			pins =  "XLSIOE_CLI13_PIN0",
				"XLSIOE_CLI13_PIN1",
				"XLSIOE_CLI13_PIN2",
				"XLSIOE_CLI13_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
		};

		//CLI 14
		cli14_2_wire_func: cli14_2_wire_func {
			pins =  "XLSIOE_CLI14_PIN0",
				"XLSIOE_CLI14_PIN1";
			function = "lsioe_cli14";
			drive-strength = <0>;
			output-disable;
			input-enable;
		};
		cli14_spi_clk_mosi_miso_func: cli14_spi_clk_mosi_miso_func {
			pins =  "XLSIOE_CLI14_PIN0",
				"XLSIOE_CLI14_PIN1",
				"XLSIOE_CLI14_PIN2";
			function = "lsioe_cli14";
			bias-pull-down;
			output-disable;
			input-enable;
		};
		cli14_spi_cs_gpio_func: cli14_spi_cs_gpio_func {
			pins = "XLSIOE_CLI14_PIN3";
			function = "lsioe_gpio";
			output-enable;
			input-enable;
		};
		cli14_4_wire_func: cli14_4_wire_func {
			pins =  "XLSIOE_CLI14_PIN0",
				"XLSIOE_CLI14_PIN1",
				"XLSIOE_CLI14_PIN2",
				"XLSIOE_CLI14_PIN3";
			function = "lsioe_cli14";
			output-disable;
			input-enable;
		};
		cli14_2_wire_sleep: cli14_2_wire_sleep {
			pins =  "XLSIOE_CLI14_PIN0",
				"XLSIOE_CLI14_PIN1";
			function = "lsioe_gpio";
			bias-pull-up;
			output-disable;
			input-enable;
		};
		cli14_4_wire_sleep: cli14_4_wire_sleep {
			pins =  "XLSIOE_CLI14_PIN0",
				"XLSIOE_CLI14_PIN1",
				"XLSIOE_CLI14_PIN2",
				"XLSIOE_CLI14_PIN3";
			function = "lsioe_gpio";
			drive-open-drain;
