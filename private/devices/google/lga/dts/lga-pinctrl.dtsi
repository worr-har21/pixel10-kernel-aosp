	aoc_pinctrl: pinctrl@B400000 {
		compatible = "google,lga-aoc-pinctrl";
		reg = <0 0xB400000 0 0x5B000>,
		      <0 0x52B9000 0 0x12000>;
		power-domains = <&sswrp_aoc_pd>;
		power-domain-names = "pad_function_pd";
		gpio-controller;
		gpio-ranges = <&aoc_pinctrl 0 0 91>;
		#gpio-cells = <2>;
		gpio-reserved-ranges = <1 1>, <3 1>, <5 1>, <7 1>, <8 1>,
				       <30 1>, <34 1>, <59 1>;

		runtime-pm-capable;
		aoc-ssr-capable;
		sswrp-wakeup-capable;

		shared-pads = <XAOC_GPIO0>,
			      <XAOC_GPIO1>,
			      <XAOC_UART0_RXD>,
			      <XAOC_UART0_TXD>,
			      <XAOC_UART0_RTSn>,
			      <XAOC_UART0_CTSn>,
			      <XAOC_GPIO2>,
			      <XAOC_GPIO3>,
			      <XAOC_GPIO4>,
			      <XAOC_GPIO5>,
			      <XAOC_GPIO6>,
			      <XAOC_GPIO7>,
			      <XAOC_GPIO8>,
			      <XAOC_GPIO9>,
			      <XAOC_GPIO10>,
			      <XAOC_GPIO11>,
			      <XAOC_GPIO12>,
			      <XAOC_GPIO13>;

		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts = <GIC_SPI SSWRP_CPM_CPM_APC_GPIO_INT_54_654 IRQ_TYPE_LEVEL_HIGH 0>, //XAOC_GPIO0
