#include <dt-bindings/soc/google/google-thermal-def.h>

/ {
	ntc_thermal: ntc_thermal {
		compatible = "google,ntc-thermal";
		#thermal-sensor-cells = <1>;
		filter-spurious-samples;
		enable-hw-lpf;
	};

	tmu_thermal: tmu_thermal {
		compatible = "google,tmu-thermal";
		#thermal-sensor-cells = <1>;
	};

	thermal_cpm_mbox: thermal_cpm_mbox {
		compatible = "thermal-cpm-mbox";
		mba-dest-channel = <MBOX_DEST_CHAN_THERMAL_V2>;
		mboxes = <&goog_mba_cpm_iface>;
	};

	thermal_devfreq_cdev {
		compatible = "google,devfreq-tj-cdev";
		thermal-hw-cdev-id = <HW_DT_CDEV_GPU>;
		thermal-devfreq = <&gpu>;
	};

	tmu_stats: tmu_stats {
		compatible = "google,tmu-stats";
		group-name = "tmu";
	};

	thermal_zones_laguna: thermal-zones {
		big_thermal: BIG {
			polling-delay = <0>;
			polling-delay-passive = <0>;
			thermal-sensors = <&tmu_thermal HW_TZ_BIG>;

			trips {
				big_cold: big-cold {
					temperature = <20000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_switch_on: big-switch-on {
					temperature = <80000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_early_throttle: big-early_throttle {
					temperature = <85000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_control_temp: big-control-temp {
					temperature = <95000>;
					hysteresis = <5000>;
					type = "passive";
				};
				big_alert1: big-alert1 {
					temperature = <97000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_sw_max_effort: big-sw_max_effort {
					temperature = <107000>;
					hysteresis = <2000>;
					type = "active";
				};
				big_dfs: big-dfs {
					temperature = <102000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_hot: big-hot {
					temperature = <115000>;
					hysteresis = <3000>;
					type = "hot";
				};
			};

			cooling-maps {
				map0 {
					trip = <&big_control_temp>;
					cooling-device =
						<&hunterelp_0 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};

			tmu {
				polling-delay-on = <5>;

				/* PI control param */
				pi-enable;
				k-po = <68>;
				k-pu = <68>;
				k-i = <50>;

				/* early throttle param */
				early-throttle-enable;
				early-throttle-k-p = <50>;

				/* gradual param */
				irq-gradual-gain = <2>;
				timer-gradual-gain = <1>;

				/* hardlimit param */
				hardlimit-enable;
				hardlimit-via-pid-enable;

				/* temp lut param */
				temp-lut-enable;

				/* Tj control offset - mC */
				junction-offset = <0 (-10000) (-10000) (-10000) 5000 0 0 0>;
			};
		};

		big_mid_thermal: BIG_MID {
			polling-delay = <0>;
			polling-delay-passive = <0>;
			thermal-sensors = <&tmu_thermal HW_TZ_BIG_MID>;

			trips {
				big_mid_cold: big-mid-cold {
					temperature = <20000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_mid_switch_on: big-mid-switch-on {
					temperature = <80000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_mid_early_throttle: big-mid-early_throttle {
					temperature = <90000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_mid_control_temp: big-mid-control-temp {
					temperature = <100000>;
					hysteresis = <5000>;
					type = "passive";
				};
				big_mid_alert1: big-mid-alert1 {
					temperature = <102000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_mid_sw_max_effort: big-mid-sw_max_effort {
					temperature = <107000>;
					hysteresis = <2000>;
					type = "active";
				};
				big_mid_dfs: big-mid-dfs {
					temperature = <105000>;
					hysteresis = <5000>;
					type = "active";
				};
				big_mid_hot: big-mid-hot {
					temperature = <115000>;
					hysteresis = <3000>;
					type = "hot";
				};
			};

			cooling-maps {
				map0 {
					trip = <&big_mid_control_temp>;
					cooling-device =
						<&hunter_3 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};

			tmu {
				polling-delay-on = <5>;

				/* PI control param */
				pi-enable;
				k-po = <68>;
				k-pu = <68>;
				k-i = <50>;

				/* early throttle param */
				early-throttle-enable;
				early-throttle-k-p = <50>;

				/* gradual param */
				irq-gradual-gain = <2>;
				timer-gradual-gain = <1>;

				/* hardlimit param */
				hardlimit-enable;
				hardlimit-via-pid-enable;

				/* Tj control offset - mC */
				junction-offset = <0 (-10000) (-10000) (-10000) 5000 0 0 0>; // mC
			};
		};

		mid_thermal: MID {
			polling-delay = <0>;
			polling-delay-passive = <0>;
			thermal-sensors = <&tmu_thermal HW_TZ_MID>;

			trips {
