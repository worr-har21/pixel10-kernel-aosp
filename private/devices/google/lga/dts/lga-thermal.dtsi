				};
			};

			tmu {
				polling-delay-on = <5>;

				/* PI control param */
				pi-enable;
				k-po = <36>;
				k-pu = <36>;
				k-i = <58>;

				/* early throttle param */
				early-throttle-enable;
				early-throttle-k-p = <50>;

				/* gradual param */
				irq-gradual-gain = <2>;
				timer-gradual-gain = <1>;

				/* hardlimit param */
				hardlimit-enable;
				hardlimit-via-pid-enable;

				/* Tj control offset - mC */
				junction-offset = <0 (-10000) (-10000) (-10000) 5000 0 0 0>; // mC
			};
		};

		little_thermal: LITTLE {
