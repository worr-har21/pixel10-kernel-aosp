&gs_governor_dsulat {
		governor_config {
			gs_dsulat_little {
				ratio_ceil = <1700>;
				stall_floor = <1750>;
				core-dev-table-latency =
				/* Little CPU    DSU */
				<  729000	 691000 >,
				< 1363000	 768000 >,
				< 1555000	 844000 >,
				< 1766000	 960000 >,
				< 1881000	1056000 >,
				< 1996000	1228000 >;

				core-dev-table-base =
				/* Little CPU    DSU */
				<  729000	 537000 >,
				< 1363000	 691000 >,
				< 1555000	 768000 >,
				< 1766000	 844000 >,
				< 1881000	 960000 >,
				< 1996000	1056000 >;
			};
			gs_dsulat_mid {
				ratio_ceil = <1000>;
				stall_floor = <1750>;
				core-dev-table-latency =
				/* Mid CPU       DSU */
