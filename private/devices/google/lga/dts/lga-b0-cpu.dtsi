				<  729000	 691000 >,
				< 1267000	 844000 >,
				< 1785000	 960000 >,
				< 1862000	1228000 >,
				< 2188000	1324000 >,
				< 2534000	1516000 >,
				< 2688000	1612000 >,
				< 2937000	1728000 >;

				core-dev-table-base =
				/* Mid CPU       DSU */
				<  729000	 691000 >,
				< 1785000	 844000 >,
				< 1862000	 960000 >,
				< 2188000	1056000 >,
				< 2688000	1132000 >,
				< 2937000	1516000 >;
			};
			gs_dsulat_big {
				ratio_ceil = <3000>;
				stall_floor = <1750>;
				core-dev-table-latency =
				/* Big CPU       DSU */
				<  533000	 691000 >,
				<  883000	 768000 >,
				< 1036000	 844000 >,
				< 1152000	 960000 >,
				< 1420000	1056000 >,
				< 1593000	1132000 >,
				< 1920000	1324000 >,
				< 2342000	1516000 >,
