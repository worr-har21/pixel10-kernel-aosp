					ldo_4m_reg: ldo_4m {
						regulator-name = "ldo_4m";
						regulator-min-microvolt = <1200000>;
						regulator-max-microvolt = <1950000>;
						// regulator-ramp-delay = <0>;
						// regulator-enable-ramp-delay = <200>;
						google,schematic-name = "L4M_BT_AON";
						google,subsystem-name = "BT";
						google,monitor-only;
					};

					ldo_5m_reg: ldo_5m {
						regulator-name = "ldo_5m";
						regulator-min-microvolt = <1200000>;
						regulator-max-microvolt = <1950000>;
						// regulator-ramp-delay = <0>;
						// regulator-enable-ramp-delay = <200>;
						google,schematic-name = "L5M_S5910_AON";
