#include <dt-bindings/interrupt-controller/irq-cpm-google.h>

// AP-PMICs DA9188 & DA9189.
/ {
	da9188mfd: da9188mfd {
		compatible = "google,da9188mfd";

		da9188_regulator: da9188-regulator {
			compatible = "google,da9188-regulator";
			mba-dest-channel = <MBOX_DEST_CHAN_DA9188_REGULATOR>;
			mboxes = <&goog_mba_cpm_iface>;

			regulators {
				/*
				* Regulators have "google,monitor-only" property means:
				* 1. This regulator is already controlled by the SoC internel HW
				* or CPM, SW driver only allow to monitor it, not control.
				* 2. This regulator should leave as default PMIC OTP value,
				* without SW driver control.
				* On the contrary, the regulator without that property have
				* full control via the SW driver.
				*
				* Currently those max min settings are from the DA9188 datasheet
				* regulator's capability. User can make a more strict limits to
				* each regulator to fit the needs of the device being powered.
				*/
				da9188 {
					buck_1m_reg: buck_1m {
						regulator-name = "buck_1m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S1M_VDD_AMB";
						google,subsystem-name = "AMB";
						google,buck-rail;
						google,monitor-only;
					};

					buck_2m_reg: buck_2m {
						regulator-name = "buck_2m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1300000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <40>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S2M_VDD_CPU2";
						google,subsystem-name = "CPU(BIG)";
						google,buck-rail;
						google,monitor-only;
					};

					buck_3m_reg: buck_3m {
						regulator-name = "buck_3m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1300000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <40>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S3M_VDD_CPU1";
						google,subsystem-name = "CPU(MID)";
						google,buck-rail;
						google,monitor-only;
					};

					buck_4m_reg: buck_4m {
						regulator-name = "buck_4m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <40>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S4M_VDD_CPU";
						google,subsystem-name = "CPU(LITTLE)";
						google,buck-rail;
						google,monitor-only;
					};

					buck_5m_reg: buck_5m {
						regulator-name = "buck_5m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1300000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S5M_VDD_AUR";
						google,subsystem-name = "AUR";
						google,buck-rail;
						google,monitor-only;
					};

					buck_6m_reg: buck_6m {
						regulator-name = "buck_6m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S6M_LLDO1";
						google,subsystem-name = "LDO";
						google,buck-rail;
						google,monitor-only;
					};

					buck_7m_reg: buck_7m {
						regulator-name = "buck_7m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1300000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <40>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S7M_VDD_TPU";
						google,subsystem-name = "TPU";
						google,buck-rail;
						google,monitor-only;
					};

					buck_8m_reg: buck_8m {
						regulator-name = "buck_8m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
