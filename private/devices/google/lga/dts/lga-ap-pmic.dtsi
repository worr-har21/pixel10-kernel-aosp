		da9188-rtc {
			compatible = "google,da9188-rtc";
			mba-dest-channel = <MBOX_DEST_CHAN_DA9188_RTC>;
			mboxes = <&goog_mba_cpm_iface>;
			wakeup-source;
			interrupt-parent = <&cpm_irq>;
			interrupts = <CPM_IRQ_RTC_ALARM_NO IRQ_TYPE_NONE>;
		};

		da9188_gpio: da9188-gpio {
			compatible = "google,da9188-gpio";
			mba-dest-channel = <MBOX_DEST_CHAN_DA9188_GPIO>;
			mboxes = <&goog_mba_cpm_iface>;
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <19>;
			gpio-line-names =
					"PMICM2CAM_LVBUCK_EN",
					"PMICM2RCAM_OIS_VM_EN",
					"PMICM2RCAM_VANA_EN",
					"PMICM2DISPPMIC_BUCK_EN",
					"PMICM2DISPPMIC_BUCK_VSEL",
					"PMICM2RCAM_VDIG_LDO_EN",
					"PMICM2LDAF_LDO_EN_1V2",
					"QI_BPP_EPP_SLCT",
					"PMICS2CAM_PMIC_EN",
					"PMICS2CAM_BB_EN",
					"PMICS2CAM_MVBUCK_EN",
					"PMICS2DISP_RESET_L",
					"PMICS2DISP2_RESET_L",
					"PMICS2DISP2PMIC_BUCK_EN",
					"PMICS2HAC_AMP_EN",
					"TP_SPARE_CAM_C28",
					"PMICS2AMP3_RESET_L_1V2",
					"PMICS2TS_RESET_L_1V2",
					"PMICS2TS2_RESET_L_1V2";
			gpio-ranges = <&da9188_gpio 0 0 19>;
		};

		da9188_vgpio: da9188-vgpio {
			compatible = "google,da9188-vgpio";
			mba-dest-channel = <MBOX_DEST_CHAN_DA9188_VGPIO>;
			mboxes = <&goog_mba_cpm_iface>;
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <32>;
			gpio-line-names =
					"DA9188_GPIO_VSOC0_EN",
					"DA9188M_GPIO_VSOC1_EN",
					"DA9188_GPIO_VSOC2_EN",
					"DA9188_GPIO_VACC0_EN",
					"DA9188_GPIO_VACC1_EN",
					"DA9188M_GPIO_VACC3_EN",
					"DA9188_GPIO_VCOLD_RST_N",
					"DA9188_GPIO_VSHUT_DOWN_N",
					"DA9188_GPIO_VWRESETI_N",
					"DA9188_GPIO_VWRSTREQ_N",
					"DA9188_GPIO_VWDT_N",
					"DA9188_GPIO_VAON_EN1",
					"DA9188_GPIO_VAON_EN0",
					"DA9188_GPIO_VBUCK11M_VT_EN",
					"DA9188_GPIO_VLDO11M_VT_EN",
					"DA9188_GPIO_VBUCK12M_VT_EN",
					"DA9188_GPIO_VBUCK6M_SR_EN",
					"DA9188_GPIO_VBUCK11M_VT_OVR",
					"DA9188_GPIO_VLDO28M_LOCK_EN",
					"DA9188_GPIO_VBR_ON_IN",
					"DA9188_GPIO_VBR_ON_LE",
					"DA9188_GPIO_VACC4_EN",
					"DA9188_GPIO_VBUCK9M_VT_EN",
					"DA9188_GPIO_VLDO15M_VT_EN",
					"DA9188_GPIO_VBUCK9M_VT_OVR",
					"DA9188_GPIO_VLDO15M_VT_OVR",
					"DA9188S_GPIO_VSOC1_EN",
					"DA9188_GPIO_VACC2_EN",
					"DA9188S_GPIO_VACC3_EN",
					"DA9188_GPIO_VBUCK3S_SR_EN",
