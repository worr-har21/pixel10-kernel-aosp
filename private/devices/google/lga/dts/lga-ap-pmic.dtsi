					buck_11m_reg: buck_11m {
						regulator-name = "buck_11m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
						// regulator-allowed-modes = <2 8>;
						google,schematic-name = "S11M_VDD_CPU_M";
						google,subsystem-name = "CPU(LITTLE)";
						google,buck-rail;
						google,monitor-only;
					};

					buck_12m_reg: buck_12m {
						regulator-name = "buck_12m";
						regulator-min-microvolt = <450000>;
						regulator-max-microvolt = <1400000>;
						// regulator-ramp-delay = <25000>;
						// regulator-enable-ramp-delay = <63>;
						// regulator-allowed-modes = <2 8>;
