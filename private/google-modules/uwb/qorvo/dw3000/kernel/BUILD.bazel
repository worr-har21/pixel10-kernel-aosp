load("//build/kernel/kleaf:kernel.bzl", "ddk_headers", "kernel_module_group")

ddk_headers(
    name = "ddk_headers",
    hdrs = glob([
        "**/*.h",
    ]),
    includes = [
        ".",
        "include",
    ],
    visibility = [
        ":__subpackages__",
    ],
)

kernel_module_group(
    name = "uwb.dw3000",
    srcs = [
        "//private/google-modules/uwb/qorvo/dw3000/kernel/drivers/net/ieee802154:dw3000",
        "//private/google-modules/uwb/qorvo/dw3000/kernel/drivers/net/ieee802154:dw3000-core-tests",
        "//private/google-modules/uwb/qorvo/dw3000/kernel/net/mcps802154",
        "//private/google-modules/uwb/qorvo/dw3000/kernel/net/mcps802154:mcps802154_region_fira",
        "//private/google-modules/uwb/qorvo/dw3000/kernel/net/mcps802154:mcps802154_region_nfcc_coex",
        "//private/google-modules/uwb/qorvo/dw3000/kernel/net/mcps802154:mcps802154_region_pctt",
    ],
    visibility = [
        "//private/devices/google:__subpackages__",
    ],
)
