        "fira_session_fsm_active.c",
        "fira_session_fsm_idle.c",
        "fira_session_fsm_init.c",
        "fira_sts.c",
        "fira_trace.c",
        "mcps_crypto.c",
    ],
    out = "mcps802154_region_fira.ko",
    copts = [
        "-Wall",
        "-Werror",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    visibility = [
        "//private/google-modules/uwb/qorvo/dw3000/kernel:__subpackages__",
