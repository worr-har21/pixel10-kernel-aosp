load("//build/kernel/kleaf:kernel.bzl", "ddk_headers", "ddk_module")

ddk_headers(
    name = "headers",
    hdrs = glob([
        "**/*.h",
    ]),
    includes = [
        ".",
    ],
)

ddk_module(
    name = "mcps802154",
    srcs = glob([
        "**/*.h",
    ]) + [
        "ca.c",
        "default_region.c",
        "endless_scheduler.c",
        "fproc.c",
        "fproc_broken.c",
        "fproc_idle.c",
        "fproc_multi.c",
        "fproc_nothing.c",
        "fproc_rx.c",
        "fproc_stopped.c",
        "fproc_tx.c",
        "fproc_vendor.c",
        "frame.c",
        "idle_region.c",
        "ie.c",
        "mcps_main.c",
        "mcps_skb_frag.c",
        "nl.c",
        "on_demand_scheduler.c",
        "ops.c",
        "regions.c",
        "schedule.c",
        "schedulers.c",
        "trace.c",
    ],
    out = "mcps802154.ko",
    copts = [
        "-Wall",
        "-Werror",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    visibility = [
        "//private/google-modules/uwb/qorvo/dw3000/kernel:__subpackages__",
    ],
    deps = [
        ":headers",
        "//common:all_headers_aarch64",
        "//private/google-modules/uwb/qorvo/dw3000/kernel:ddk_headers",
    ],
)

