load("@bazel_skylib//rules:common_settings.bzl", "bool_flag")
load("//build/kernel/kleaf:kernel.bzl", "checkpatch", "ddk_headers", "ddk_module", "kernel_module_group")

checkpatch(
    name = "checkpatch",
    checkpatch_pl = "//common:scripts/checkpatch.pl",
)

bool_flag(
    name = "cpif_with_dit",
    build_setting_default = False,
)

config_setting(
    name = "cpif_with_dit_is_true",
    flag_values = {
        ":cpif_with_dit": "true",
    },
)

filegroup(
    name = "cpif.kconfig",
    srcs = [
        "Kconfig",
    ],
    visibility = [
        "//private/devices/google:__subpackages__",
    ],
)

ddk_headers(
    name = "headers",
    hdrs = glob([
        "**/*.h",
    ]),
    includes = [
        ".",
    ],
    visibility = [
        ":__subpackages__",
    ],
)

ddk_module(
    name = "mcu_ipc",
    srcs = glob([
        "**/*.h",
    ]) + [
        "mcu_ipc.c",
    ],
    out = "mcu_ipc.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

ddk_module(
    name = "shm_ipc",
    srcs = glob([
        "**/*.h",
    ]) + [
        "shm_ipc.c",
    ],
    out = "shm_ipc.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

ddk_module(
    name = "boot_device_spi",
    srcs = glob([
        "**/*.h",
    ]) + [
        "boot_device_spi.c",
    ],
    out = "boot_device_spi.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

ddk_module(
    name = "cpif_page",
    srcs = glob([
        "**/*.h",
    ]) + [
        "cpif_page.c",
    ],
    out = "cpif_page.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    visibility = [
        "//private/google-modules/radio/samsung/s5300/dit:__subpackages__",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

ddk_module(
    name = "direct_dm",
    srcs = glob([
        "**/*.h",
    ]) + [
        "direct_dm.c",
    ],
    out = "direct_dm.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
