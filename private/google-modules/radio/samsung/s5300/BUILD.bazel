ddk_module(
    name = "hook",
    srcs = glob([
        "**/*.h",
    ]) + [
        "hook.c",
    ],
    out = "hook.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

ddk_module(
    name = "cpif_ko",
    srcs = glob([
        "**/*.h",
    ]) + [
        "bootdump_io_device.c",
        "ipc_io_device.c",
        "link_device.c",
        "link_device_memory_debug.c",
        "link_device_memory_flow_control.c",
        "link_device_memory_legacy.c",
        "link_device_memory_snapshot.c",
        "modem_dump.c",
        "modem_io_device.c",
        "modem_main.c",
        "modem_toe_device.c",
        "modem_utils.c",
        "modem_variation.c",
        "net_io_device.c",
    ],
    out = "cpif.ko",
    conditional_srcs = {
        "CONFIG_CPIF_TP_MONITOR": {
            True: [
                "cpif_tp_monitor.c",
            ],
        },
        "CONFIG_CP_BTL": {
            True: [
                "cp_btl.c",
            ],
        },
        "CONFIG_CP_PKTPROC": {
            True: [
                "link_rx_pktproc.c",
            ],
        },
        "CONFIG_CP_PKTPROC_UL": {
            True: [
                "link_tx_pktproc.c",
            ],
        },
        "CONFIG_EXYNOS_CPIF_IOMMU": {
            True: [
                "cpif_netrx_mng.c",
                "cpif_vmapper.c",
            ],
        },
        "CONFIG_LINK_DEVICE_PCIE": {
            True: [
                "s51xx_pcie.c",
            ],
        },
        "CONFIG_LINK_DEVICE_PCIE_IOMMU": {
            True: [
                "link_device_pcie_iommu.c",
            ],
        },
        "CONFIG_LINK_DEVICE_WITH_SBD_ARCH": {
            True: [
                "link_device_memory_sbd.c",
            ],
        },
        "CONFIG_MODEM_IF_LEGACY_QOS": {
            True: [
                "cpif_qos_info.c",
            ],
        },
        "CONFIG_SEC_MODEM_S5000AP": {
            True: [
                "modem_ctrl.c",
                "modem_ctrl_s5000ap.c",
            ],
        },
        "CONFIG_SEC_MODEM_S5100": {
            True: [
                "modem_ctrl.c",
                "modem_ctrl_s5100.c",
            ],
        },
    },
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        ":shm_ipc",
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:bms-misc",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:gs_soc_module",
        "//private/google-modules/soc/gs:headers",
    ] + select({
        ":cpif_with_dit_is_true": [
            ":boot_device_spi",
            "//private/google-modules/radio/samsung/s5300/dit:exynos_dit",
        ],
        "//conditions:default": [
            "//private/google-modules/soc/gs/drivers/misc/s5910",
        ],
    }),
)

ddk_module(
    name = "cp_thermal_zone",
    srcs = glob([
        "**/*.h",
    ]) + [
        "cp_thermal_zone.c",
    ],
    out = "cp_thermal_zone.ko",
    copts = [
        "-Wformat",
        "-Wformat-zero-length",
        "-Wno-missing-prototypes",
    ],
    kernel_build = "//private/devices/google/common:kernel",
    local_defines = [
        "CONFIG_OPTION_REGION=\"$(PROJECT_REGION)\"",
        "CPIF_WAKEPKT_SET_MARK=0x80000000",
    ],
    deps = [
        "//common:all_headers_aarch64",
        "//private/google-modules/bms/misc:headers",
        "//private/google-modules/soc/gs:headers",
    ],
)

kernel_module_group(
    name = "cpif",
    srcs = [
        ":cp_thermal_zone",
        ":cpif_ko",
        ":cpif_page",
        ":shm_ipc",
    ],
    visibility = [
        "//private/devices/google:__subpackages__",
    ],
)

kernel_module_group(
    name = "cpif.dit",
    srcs = [
        ":boot_device_spi",
        ":cp_thermal_zone",
        ":cpif_ko",
        ":cpif_page",
        ":shm_ipc",
        "//private/google-modules/radio/samsung/s5300/dit:exynos_dit",
    ],
    visibility = [
        "//private/devices/google:__subpackages__",
    ],
)
